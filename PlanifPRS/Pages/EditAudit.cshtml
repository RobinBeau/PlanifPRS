@page "{id:int}"
@model PlanifPRS.Pages.Prs.EditAuditModel
@{
    ViewData["Title"] = "Modifier un Événement";
}
@section Styles {
    <link rel="stylesheet" href="~/css/create-prs.css" asp-append-version="true" />
    <style>
        .event-type-card {
            transition: .25s;
            cursor: pointer;
            border: 2px solid transparent;
        }

            .event-type-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 6px 18px rgba(0,0,0,.15);
            }

            .event-type-card.selected {
                border-color: #667eea;
                background: linear-gradient(135deg,rgba(102,126,234,.10),rgba(118,75,162,.10));
            }

        #affectationsList li .btn-remove-aff {
            opacity: .65;
            transition: .15s;
        }

            #affectationsList li .btn-remove-aff:hover {
                opacity: 1;
            }
    </style>
}

<div class="page-container">
    @if (Model.Prs == null)
    {
        <div class="alert alert-danger"><i class="fas fa-exclamation-triangle me-2"></i>Événement introuvable.</div>
    }
    else
    {
        <div class="page-header">
            <h1 class="page-title"><i class="fas fa-edit me-2"></i>@ViewData["Title"]</h1>
            <p class="page-subtitle">Modifier audit / intervention / visite client</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <strong>Erreurs :</strong>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>• @e.ErrorMessage</div>
                }
            </div>
        }

        <div class="mb-4">
            <h5 class="mb-3"><i class="fas fa-list-alt me-2"></i>Type d'événement</h5>
            <div class="row g-3">
                @foreach (var t in new[] { "Audit", "Intervention", "Visite Client" })
                {
                    var icon = t switch
                    {
                        "Audit" => "fa-clipboard-check text-danger",
                        "Intervention" => "fa-tools text-warning",
                        _ => "fa-handshake text-info"
                    };
                    <div class="col-md-4">
                        <div class="card event-type-card h-100" data-event-type="@t">
                            <div class="card-body text-center">
                                <i class="fas @icon fa-3x mb-3"></i>
                                <h6 class="card-title mb-1">@t</h6>
                                <p class="text-muted small mb-0">
                                    @(t == "Audit" ? "Conformité" : "Intervention" == t ? "Maintenance" : "Relation")
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <form method="post" id="edit-audit-form" class="row g-3">
            <input type="hidden" asp-for="Prs.Id" />
            <input type="hidden" id="EventType" name="EventType" value="@Model.PreselectedEventType" />
            <input type="hidden" id="affectationsData" name="AffectationsData" value='@Model.AffectationsData' />
            <input type="hidden" id="affectationsToDelete" name="AffectationsToDelete" value="[]" />

            <div class="col-md-8">
                <label class="form-label fw-bold"><i class="fas fa-edit me-1"></i>Détails *</label>
                <input type="text" id="EventDetails" name="EventDetails" class="form-control"
                       value="@Model.PreselectedEventDetails" required />
            </div>
            <div class="col-md-4">
                <label asp-for="Prs.LigneId" class="form-label fw-bold"><i class="fas fa-industry me-1"></i>Ligne *</label>
                <select asp-for="Prs.LigneId" asp-items="Model.LigneList" class="form-select" required>
                    <option value="">-- Choisir --</option>
                </select>
                <span asp-validation-for="Prs.LigneId" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white py-2"><strong><i class="fas fa-clock me-1"></i>Planification</strong></div>
                    <div class="card-body row g-3">
                        <div class="col-md-6">
                            <label asp-for="Prs.DateDebut" class="form-label">Début *</label>
                            <input asp-for="Prs.DateDebut" type="datetime-local" class="form-control"
                                   value="@Model.Prs.DateDebut.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Prs.DateFin" class="form-label">Fin *</label>
                            <input asp-for="Prs.DateFin" type="datetime-local" class="form-control"
                                   value="@Model.Prs.DateFin.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="Prs.InfoDiverses" class="form-label fw-bold"><i class="fas fa-comment-dots me-1"></i>Infos</label>
                <textarea asp-for="Prs.InfoDiverses" rows="3" class="form-control" placeholder="Remarques...">@Model.Prs.InfoDiverses</textarea>
            </div>

            <!-- AFFECTATIONS -->
            <div class="col-12">
                <div class="card border-secondary">
                    <div class="card-header bg-secondary text-white py-2"><strong><i class="fas fa-users me-1"></i>Affectations</strong></div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-user me-1"></i>Utilisateur</label>
                                <div class="input-group">
                                    <select id="userSelect" class="form-select">
                                        <option value="">Sélectionner...</option>
                                        @foreach (var u in Model.UtilisateursList)
                                        {
                                            <option value="@u.Id"
                                                    data-name="@u.Nom @u.Prenom"
                                                    data-service="@u.Service"
                                                    data-email="@u.Mail">
                                                @u.Nom @u.Prenom (@u.Service)
                                            </option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-primary" id="addUserBtn">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-users me-1"></i>Groupe</label>
                                <div class="input-group">
                                    <select id="groupSelect" class="form-select">
                                        <option value="">Sélectionner...</option>
                                        @foreach (var g in Model.GroupesList)
                                        {
                                            <option value="@g.Id"
                                                    data-name="@g.NomGroupe"
                                                    data-count="@g.Membres?.Count">
                                                @g.NomGroupe (@(g.Membres?.Count ?? 0) membres)
                                            </option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-success" id="addGroupBtn">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <h6><i class="fas fa-list me-1"></i>Liste</h6>
                            <ul id="affectationsList" class="list-group">
                                @if (Model.AffectationsExistantes.Any())
                                {
                                    @foreach (var a in Model.AffectationsExistantes)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center"
                                            data-existing="true"
                                            data-affectation-id="@a.AffectationId"
                                            data-type="@a.Type"
                                            data-source-id="@a.SourceId"
                                            data-email="@a.Email">
                                            <div>
                                                <i class="fas @(a.Type=="Utilisateur"?"fa-user":"fa-users") me-2"></i>
                                                <strong>@a.Nom</strong>
                                                <span class="badge @(a.Type=="Utilisateur"?"bg-primary":"bg-success") ms-2">@a.Type</span>
                                                @if (!string.IsNullOrEmpty(a.Info))
                                                {
                                                    <br />

                                                    <small class="text-muted">@a.Info</small>
                                                }
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-aff">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item text-muted">
                                        <i class="fas fa-info-circle me-2"></i>Aucune affectation.
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="Prs.Statut" />
            <input type="hidden" asp-for="Prs.FamilleId" />
            <input type="hidden" asp-for="Prs.DateCreation" />

            <div class="col-12 text-center mt-3">
                <button type="submit" class="btn btn-primary btn-lg px-5 me-3" id="submit-btn" disabled>
                    <i class="fas fa-save me-2"></i><span id="submit-text">Sélectionnez d'abord un type d'événement</span>
                </button>
                <a asp-page="/Index" class="btn btn-secondary btn-lg px-5 me-3"><i class="fas fa-times me-2"></i>Annuler</a>
                @if (Model.CanDelete && Model.Prs.Statut != "Supprimé")
                {
                    <form method="post" asp-page-handler="Supprimer" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Prs.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-lg px-5">
                            <i class="fas fa-trash me-2"></i>Supprimer
                        </button>
                    </form>
                }
            </div>
        </form>
    }
</div>

<div class="calendar-section-title mt-5">
    <h5 class="calendar-standalone-title"><i class="fas fa-calendar-alt me-1"></i> Planning existant</h5>
</div>
@Html.Partial("_CalendarBlock")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        /* === TYPE === */
        const eventTypeInput=document.getElementById('EventType');
        const eventDetailsInput=document.getElementById('EventDetails');
        const ligneSelect=document.querySelector('select[name="Prs.LigneId"]');
        const submitBtn=document.getElementById('submit-btn');
        const submitText=document.getElementById('submit-text');
        document.querySelectorAll('.event-type-card').forEach(card=>{
            card.addEventListener('click', ()=>{
                document.querySelectorAll('.event-type-card').forEach(c=>c.classList.remove('selected'));
                card.classList.add('selected');
                eventTypeInput.value=card.dataset.eventType;
                updateSubmit();
            });
            if(card.dataset.eventType===eventTypeInput.value) card.classList.add('selected');
        });
        function updateSubmit(){
            const ok=eventTypeInput.value && eventDetailsInput.value.trim() && ligneSelect.value;
            if(ok){
                submitBtn.disabled=false;
                submitBtn.className='btn btn-success btn-lg px-5 me-3';
                submitText.textContent='Valider '+eventTypeInput.value;
            } else {
                submitBtn.disabled=true;
                if(!eventTypeInput.value){submitText.textContent="Sélectionnez d'abord un type d'événement";submitBtn.className='btn btn-primary btn-lg px-5 me-3';}
                else if(!eventDetailsInput.value.trim()){submitText.textContent="Saisissez les détails de l'événement";submitBtn.className='btn btn-warning btn-lg px-5 me-3';}
                else {submitText.textContent="Sélectionnez une ligne";submitBtn.className='btn btn-info btn-lg px-5 me-3';}
            }
        }
        eventDetailsInput.addEventListener('input', updateSubmit);
        ligneSelect.addEventListener('change', updateSubmit);

        document.getElementById('edit-audit-form').addEventListener('submit', e=>{
            if(submitBtn.disabled){ e.preventDefault(); return; }
            const d1=new Date(document.querySelector('[name="Prs.DateDebut"]').value);
            const d2=new Date(document.querySelector('[name="Prs.DateFin"]').value);
            if(d2<=d1){ e.preventDefault(); alert('Fin doit être après début'); return; }
            submitBtn.disabled=true;
            submitBtn.innerHTML='<i class="fas fa-spinner fa-spin me-2"></i>Validation...';
        });

        /* === AFFECTATIONS (diff final) === */
        const affectationsList=document.getElementById('affectationsList');
        const hiddenUnion=document.getElementById('affectationsData');
        const delHidden=document.getElementById('affectationsToDelete'); // plus utilisé pour la logique serveur
        const userSelect=document.getElementById('userSelect');
        const groupSelect=document.getElementById('groupSelect');
        const addUserBtn=document.getElementById('addUserBtn');
        const addGroupBtn=document.getElementById('addGroupBtn');

        let existing=[]; // {id,type,affectationId,email}
        let added=[];    // {id,type,email}

        function loadExisting(){
            existing=[];
            affectationsList.querySelectorAll('li[data-existing="true"]').forEach(li=>{
                const type=li.getAttribute('data-type');
                const id=parseInt(li.getAttribute('data-source-id')||'0',10);
                const affId=parseInt(li.getAttribute('data-affectation-id')||'0',10);
                const email=(li.getAttribute('data-email')||'').trim();
                if(type && id) existing.push({id,type,affectationId:affId,email});
            });
        }

        function buildFinal(){
            // final= existing actifs + added
            return [
                ...existing.map(e=>({id:e.id,type:e.type,email:e.type==='Utilisateur'?(e.email||''):''})),
                ...added.map(a=>({id:a.id,type:a.type,email:a.type==='Utilisateur'?(a.email||''):''}))
            ];
        }

        function writeFinal(triggerCal=true){
            hiddenUnion.value=JSON.stringify(buildFinal());
            if(triggerCal){
                document.dispatchEvent(new CustomEvent('affectations:changed',{
                    detail:{ affectations: buildFinal() }
                }));
                if(typeof window.__prsRefreshAbsences==='function'){
                    try{ window.__prsRefreshAbsences(); }catch{}
                } else {
                    let tries=0;
                    (function retry(){
                        if(typeof window.__prsRefreshAbsences==='function'){ try{window.__prsRefreshAbsences();}catch{} }
                        else if(++tries<30) setTimeout(retry,200);
                    })();
                }
            }
        }

        function ensureEmptyRow(){
            if(!existing.length && !added.length){
                affectationsList.innerHTML='<li class="list-group-item text-muted"><i class="fas fa-info-circle me-2"></i>Aucune affectation.</li>';
            }
        }

        function addVisualEntry(entry){
            if(affectationsList.querySelector('li.text-muted')) affectationsList.innerHTML='';
            const li=document.createElement('li');
            li.className='list-group-item d-flex justify-content-between align-items-center';
            li.innerHTML=`
              <div>
                <i class="fas ${entry.type==='Utilisateur'?'fa-user':'fa-users'} me-2"></i>
                <strong>${entry.name}</strong>
                <span class="badge ${entry.type==='Utilisateur'?'bg-primary':'bg-success'} ms-2">${entry.type}</span>
                ${entry.info?`<br><small class="text-muted">${entry.info}</small>`:''}
              </div>
              <button type="button" class="btn btn-sm btn-outline-danger btn-remove-aff"><i class="fas fa-times"></i></button>`;
            li.querySelector('.btn-remove-aff').addEventListener('click', ()=>{
                // suppression d'un ajouté
                added = added.filter(a=> !(a.id===entry.id && a.type===entry.type));
                li.remove();
                writeFinal();
                ensureEmptyRow();
            });
            affectationsList.appendChild(li);
        }

        addUserBtn.addEventListener('click', ()=>{
            const opt=userSelect.selectedOptions[0];
            if(!opt||!opt.value) return;
            const id=parseInt(opt.value,10);
            if(existing.some(e=>e.type==='Utilisateur'&&e.id===id) || added.some(a=>a.type==='Utilisateur'&&a.id===id)) return;
            const name=(opt.dataset.name||opt.textContent).trim();
            const info=opt.dataset.service||'';
            const email=(opt.dataset.email||'').trim();
            added.push({id,type:'Utilisateur',email});
            addVisualEntry({id,type:'Utilisateur',name,info});
            writeFinal();
            userSelect.value='';
        });

        addGroupBtn.addEventListener('click', ()=>{
            const opt=groupSelect.selectedOptions[0];
            if(!opt||!opt.value) return;
            const id=parseInt(opt.value,10);
            if(existing.some(e=>e.type==='Groupe'&&e.id===id) || added.some(a=>a.type==='Groupe'&&a.id===id)) return;
            const name=(opt.dataset.name||opt.textContent).trim();
            const info=opt.dataset.count ? (opt.dataset.count+' membres') : '';
            added.push({id,type:'Groupe',email:''});
            addVisualEntry({id,type:'Groupe',name,info});
            writeFinal();
            groupSelect.value='';
        });

        // Suppressions existantes
        affectationsList.querySelectorAll('li[data-existing="true"] .btn-remove-aff').forEach(btn=>{
            btn.addEventListener('click', ()=>{
                const li=btn.closest('li');
                const type=li.getAttribute('data-type');
                const id=parseInt(li.getAttribute('data-source-id')||'0',10);
                // retirer du tableau existant
                existing = existing.filter(e=> !(e.type===type && e.id===id));
                li.remove();
                writeFinal();
                ensureEmptyRow();
            });
        });

        document.addEventListener('DOMContentLoaded', ()=>{
            loadExisting();
            ensureEmptyRow();
            writeFinal(false); // initial sans spam calendrier
            setTimeout(()=>writeFinal(),300);
            setTimeout(()=>writeFinal(),1000);
            updateSubmit();
        });

        /* Dates cohérentes */
        const dStart=document.querySelector('[name="Prs.DateDebut"]');
        const dEnd=document.querySelector('[name="Prs.DateFin"]');
        dStart.addEventListener('change', ()=>{
            const s=new Date(dStart.value), e=new Date(dEnd.value);
            if(e<=s){ const ns=new Date(s.getTime()+2*3600000); dEnd.value=ns.toISOString().slice(0,16); }
        });
        dEnd.addEventListener('change', ()=>{
            const s=new Date(dStart.value), e=new Date(dEnd.value);
            dEnd.style.borderColor = (e<=s)?'#dc3545':'';
        });
    </script>
}