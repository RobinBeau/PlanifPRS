@page
@model PlanifPRS.Pages.MilestonesModel
@{
    ViewData["Title"] = "Gestion des Tâches";
    var today = DateTime.Today;
}

<div class="milestones-container">
    <!-- En-tête -->
    <div class="header d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="page-title">
                <i class="fas fa-flag-checkered me-2"></i>Gestion des Tâches
            </h1>
            <div class="text-muted">
                @Model.CurrentUserLogin
                @if (Model.IsManagerView)
                {
                        <span class="badge bg-danger ms-2">
                            <i class="fas fa-crown me-1"></i>Admin
                        </span>
                }
                @if (Model.IsChefService)
                {
                        <span class="badge bg-warning text-dark ms-2">
                            <i class="fas fa-users-cog me-1"></i>Chef de Service (@Model.ServiceName)
                        </span>
                }
            </div>
        </div>
        <div class="text-muted">
            <i class="fas fa-calendar me-1"></i>@today.ToString("dd/MM/yyyy")
        </div>
    </div>

    <!-- Messages -->
    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }
    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }

    @* ========== SECTION ADMIN : TOUTES LES TÂCHES ========== *@
    @if (Model.IsManagerView && Model.AllChecklistItems != null && Model.AllChecklistItems.Any())
    {
            <h3 class="section-title mt-4 mb-3">
                <i class="fas fa-globe me-2"></i>Toutes les tâches (vue globale)
            </h3>

        var allTotal = Model.AllChecklistItems.Count;
        var allValides = Model.AllChecklistItems.Count(i => i.IsValidated);
        var allRetard = Model.AllChecklistItems.Count(i => i.IsLate);
        var allEnCours = allTotal - allValides - allRetard;

            <div class="row g-3 mb-3">
                <div class="col-6 col-md-3">
                    <div class="card kpi-card shadow-sm border-secondary">
                        <div class="card-body">
                            <div class="kpi-title text-muted">Total</div>
                            <div class="kpi-value text-secondary">@allTotal</div>
                            <div class="kpi-sub text-muted">Tâches</div>
                        </div>
                        <div class="kpi-icon text-secondary"><i class="fas fa-list-ol"></i></div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card kpi-card shadow-sm border-success">
                        <div class="card-body">
                            <div class="kpi-title text-muted">Validées</div>
                            <div class="kpi-value text-success">@allValides</div>
                            <div class="kpi-sub text-muted">Terminées</div>
                        </div>
                        <div class="kpi-icon text-success"><i class="fas fa-check-circle"></i></div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card kpi-card shadow-sm border-warning">
                        <div class="card-body">
                            <div class="kpi-title text-muted">En cours</div>
                            <div class="kpi-value text-warning">@allEnCours</div>
                            <div class="kpi-sub text-muted">À faire</div>
                        </div>
                        <div class="kpi-icon text-warning"><i class="fas fa-clock"></i></div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card kpi-card shadow-sm border-danger">
                        <div class="card-body">
                            <div class="kpi-title text-muted">En retard</div>
                            <div class="kpi-value text-danger">@allRetard</div>
                            <div class="kpi-sub text-muted">Urgentes</div>
                        </div>
                        <div class="kpi-icon text-danger"><i class="fas fa-exclamation-triangle"></i></div>
                    </div>
                </div>
            </div>

        @* Tableau Admin *@
            <div class="card shadow-sm mb-3 p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-6">
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="filter-btn" data-table="allTasksTable" data-filter="all">
                                <i class="fas fa-globe me-1"></i>Tous
                            </button>
                            <button class="filter-btn" data-table="allTasksTable" data-filter="retard">
                                <i class="fas fa-exclamation-triangle me-1"></i>En retard
                            </button>
                            <button class="filter-btn" data-table="allTasksTable" data-filter="encours">
                                <i class="fas fa-clock me-1"></i>En cours
                            </button>
                            <button class="filter-btn" data-table="allTasksTable" data-filter="valide">
                                <i class="fas fa-check-circle me-1"></i>Validés
                            </button>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" class="form-control search-input" data-table="allTasksTable" placeholder="Rechercher...">
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mb-4">
                <table class="table table-hover align-middle" id="allTasksTable">
                    <thead>
                        <tr>
                            <th style="width:30%">PRS - Tâche</th>
                            <th style="width:15%">Catégorie</th>
                            <th style="width:15%">Échéance</th>
                            <th style="width:12%">Délai</th>
                            <th style="width:13%">Statut</th>
                            <th style="width:15%">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var it in Model.AllChecklistItems)
                    {
                        var statusClass = it.IsValidated ? "valide" : (it.IsLate ? "retard" : "encours");
                                <tr class="task-row" data-status="@statusClass" data-searchable="@($"{it.PrsTitre} {it.Categorie} {it.Libelle}")">
                                    <td>
                                        <div class="fw-semibold text-primary small mb-1">
                                            <i class="fas fa-bookmark me-1"></i>@it.PrsTitre
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fas fa-clipboard-check me-1"></i>@it.Libelle
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">@it.Categorie</div>
                                @if (!string.IsNullOrWhiteSpace(it.SousCategorie))
                                {
                                                <small class="text-muted">@it.SousCategorie</small>
                                }
                                    </td>
                                    <td>
                                        <div class="fw-semibold small mb-1">@it.DueDate.ToString("dd/MM/yyyy")</div>
                                @if (!it.IsValidated)
                                {
                                    if (it.DaysLeft > 0)
                                    {
                                                        <span class="badge bg-info text-dark">Dans @it.DaysLeft j</span>
                                    }
                                    else if (it.DaysLeft == 0)
                                    {
                                                        <span class="badge bg-warning text-dark">Aujourd'hui</span>
                                    }
                                    else
                                    {
                                                        <span class="badge bg-danger">@Math.Abs(it.DaysLeft) j retard</span>
                                    }
                                }
                                else
                                {
                                                <span class="badge bg-success">Validé</span>
                                }
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary me-1">P @it.Priorite</span>
                                        <span class="badge bg-info">@it.DelaiJours j</span>
                                    </td>
                                    <td>
                                @if (it.IsValidated)
                                {
                                                <div>
                                                    <span class="badge bg-success mb-1">
                                                        <i class="fas fa-check-circle me-1"></i>Validé
                                                    </span>
                                                    <div class="small text-muted">
                                            @it.DateValidation?.ToString("dd/MM/yyyy")<br>
                                                        par @(it.ValidePar ?? "-")
                                                    </div>
                                                </div>
                                }
                                else
                                {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-clock me-1"></i>En cours
                                                </span>
                                }
                                    </td>
                                    <td>
                                @if (!it.IsValidated)
                                {
                                                <form method="post" asp-page-handler="ValidateChecklist" class="d-inline">
                                                    <input type="hidden" name="checklistId" value="@it.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-check me-1"></i>Valider
                                                    </button>
                                                </form>
                                }
                                else
                                {
                                                <form method="post" asp-page-handler="UnvalidateChecklist" class="d-inline">
                                                    <input type="hidden" name="checklistId" value="@it.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-undo me-1"></i>Annuler
                                                    </button>
                                                </form>
                                }
                                    </td>
                                </tr>
                    }
                    </tbody>
                </table>
            </div>
    }

    @* ========== SECTION CHEF DE SERVICE ========== *@
    @if (Model.IsChefService && Model.ServiceChecklistItems != null && Model.ServiceChecklistItems.Any())
