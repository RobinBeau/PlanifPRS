@page
@model PlanifPRS.Pages.MilestonesModel
@{
    ViewData["Title"] = "Gestion des Checklists PRS";
    var today = DateTime.Today;
}

<div class="milestones-container">
    <!-- En-tête moderne -->
    <div class="milestones-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="page-title">
                    <i class="fas fa-flag-checkered me-3"></i>Gestion des Checklists PRS
                </h1>
                <p class="page-subtitle">
                    <i class="fas fa-info-circle me-1"></i>Suivez l'avancement des éléments de checklist et identifiez les retards
                    <span class="ms-3"><i class="fas fa-calendar me-1"></i>Aujourd'hui : @today.ToString("dd/MM/yyyy")</span>
                </p>
            </div>
            <div class="stats-summary">
                @{
                    var totalItems = Model.Groups?.Sum(g => g.TotalItems) ?? 0;
                    var itemsValides = Model.Groups?.Sum(g => g.ValidatedItems) ?? 0;
                    var itemsEnRetard = Model.Groups?.Sum(g => g.LateCount) ?? 0;
                    var itemsEnCours = totalItems - itemsValides - itemsEnRetard;
                }
                <div class="stat-badge stat-total">
                    <i class="fas fa-list-ol"></i>
                    <span>@totalItems</span>
                    <small>Total</small>
                </div>
                <div class="stat-badge stat-success">
                    <i class="fas fa-check-circle"></i>
                    <span>@itemsValides</span>
                    <small>Validés</small>
                </div>
                <div class="stat-badge stat-warning">
                    <i class="fas fa-clock"></i>
                    <span>@itemsEnCours</span>
                    <small>En cours</small>
                </div>
                <div class="stat-badge stat-danger">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>@itemsEnRetard</span>
                    <small>En retard</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres et actions -->
    <div class="actions-panel">
        <div class="filters-section">
            <div class="filter-group">
                <label class="filter-label">
                    <i class="fas fa-filter me-1"></i>Filtrer par statut (éléments)
                </label>
                <div class="filter-buttons">
                    <button class="filter-btn active" data-filter="all">
                        <i class="fas fa-globe"></i>Tous
                    </button>
                    <button class="filter-btn" data-filter="valide">
                        <i class="fas fa-check-circle"></i>Validés
                    </button>
                    <button class="filter-btn" data-filter="encours">
                        <i class="fas fa-clock"></i>En cours
                    </button>
                    <button class="filter-btn" data-filter="retard">
                        <i class="fas fa-exclamation-triangle"></i>En retard
                    </button>
                </div>
            </div>
        </div>

        <div class="search-section">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Rechercher (PRS, libellé, catégorie)...">
            </div>
        </div>

        <!-- Filtres PRS (client, sans bouton) -->
        <div class="d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label class="filter-label">
                    <i class="fas fa-diagram-project me-1"></i>PRS
                </label>
                <select id="filterPrsName" class="form-select">
                    <option value="">Toutes les PRS</option>
                    @if (Model.PrsOptions != null)
                    {
                        foreach (var n in Model.PrsOptions)
                        {
                            <option value="@n">@n</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="filter-label">
                    <i class="fas fa-traffic-light me-1"></i>Statut PRS
                </label>
                <select id="filterPrsState" class="form-select">
                    <option value="all">Tous</option>
                    <option value="attente">En attente</option>
                    <option value="valide">Validé</option>
                </select>
            </div>

            <!-- Quick filters -->
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-primary btn-sm quick-filter" data-qf="me">
                    <i class="fas fa-user-check me-1"></i>Mes éléments
                </button>
                <button class="btn btn-outline-primary btn-sm quick-filter" data-qf="groups">
                    <i class="fas fa-users me-1"></i>Mes groupes
                </button>
                <button class="btn btn-outline-danger btn-sm quick-filter" data-qf="late">
                    <i class="fas fa-exclamation-triangle me-1"></i>En retard uniquement
                </button>
                <button class="btn btn-outline-warning btn-sm quick-filter" data-qf="today">
                    <i class="fas fa-calendar-day me-1"></i>À valider aujourd'hui
                </button>
            </div>

            <!-- Seuil échéance proche -->
            <div class="d-flex align-items-center gap-2">
                <label class="filter-label m-0">
                    <i class="fas fa-bell me-1"></i>Échéance proche (j)
                </label>
                <input type="range" id="dueSoonSlider" min="1" max="14" value="3" />
                <span id="dueSoonValue" class="badge bg-secondary">3</span>
            </div>
        </div>
    </div>

    <!-- GROUPES PRS (pliables) -->
    <div id="prsContainer" class="accordion" data-sort-groups="asc">
        @if (Model.Groups != null && Model.Groups.Any())
        {
            var groupIndex = 0;
            foreach (var grp in Model.Groups)
            {
                var accId = $"prs-{grp.PrsId}";
                var headingId = $"h-{grp.PrsId}";
                var progress = grp.TotalItems > 0 ? (int)Math.Round(100.0 * grp.ValidatedItems / grp.TotalItems) : 0;
                var statutBadgeClass = grp.PrsStatut == "Validé" ? "bg-success" : "bg-secondary";

                <div class="accordion-item mb-2 prs-group" id="@accId" data-prs-title="@grp.PrsTitre" data-prsstate="@grp.PrsState">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@grp.PrsId" aria-expanded="false" aria-controls="collapse-@grp.PrsId">
                            <div class="w-100 d-flex align-items-center justify-content-between">
                                <div class="d-flex flex-column">
                                    <div class="d-flex align-items-center gap-2">
                                        <strong class="me-2">@grp.PrsTitre</strong>
                                        <span class="badge @statutBadgeClass">Statut PRS: @grp.PrsStatut</span>
                                        <span class="badge bg-info">@grp.TotalItems élément(s)</span>
                                        <span class="badge bg-success">@grp.ValidatedItems validé(s)</span>
                                        @if (grp.LateCount > 0)
                                        {
                                            <span class="badge bg-danger">@grp.LateCount en retard</span>
                                        }
                                        @if (grp.DueSoonCount > 0)
                                        {
                                            <span class="badge bg-warning text-dark">@grp.DueSoonCount proche</span>
                                        }
                                    </div>
                                    <div class="progress mt-2" style="height: 8px; width: 320px;">
                                        <div class="progress-bar" role="progressbar" style="width:@progress%" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="text-end small text-muted ms-3">
                                    PRS #@grp.PrsId
                                </div>
                            </div>
                        </button>
                    </h2>
                    <div id="collapse-@grp.PrsId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#prsContainer">
                        <div class="accordion-body">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle checklist-table" data-group-prs="@grp.PrsTitre">
                                    <thead class="table-light">
                                        <tr>
                                            <th data-sort-key="categorie" class="sortable">
                                                <i class="fas fa-tags me-1"></i>Catégorie
                                            </th>
                                            <th data-sort-key="libelle" class="sortable">
                                                <i class="fas fa-clipboard-check me-1"></i>Libellé
                                            </th>
                                            <th data-sort-key="priorite" class="sortable">
                                                <i class="fas fa-sort-numeric-up me-1"></i>Priorité
                                            </th>
                                            <th data-sort-key="due" class="sortable">
                                                <i class="fas fa-calendar-alt me-1"></i>Date prévue
                                            </th>
                                            <th data-sort-key="statut" class="sortable">
                                                <i class="fas fa-check-square me-1"></i>Statut
                                            </th>
                                            <th>
                                                <i class="fas fa-bolt me-1"></i>Action
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var it in grp.Items)
                                        {
                                            var statusClass = it.IsValidated ? "valide" : (it.IsLate ? "retard" : "encours");
                                            var dueTicks = it.DueDate.Ticks; // pour tri date
                                            <tr class="checklist-row"
                                                data-status="@statusClass"
                                                data-searchable="@($"{grp.PrsTitre} {it.Categorie} {it.SousCategorie} {it.Libelle}")"
                                                data-prs="@grp.PrsTitre"
                                                data-prsstate="@grp.PrsState"
                                                data-daysleft="@it.DaysLeft"
                                                data-priority="@it.Priorite"
                                                data-dueticks="@dueTicks"
                                                data-assignee-me="@(it.IsAssignedToMe ? "1" : "0")"
                                                data-assignee-group="@(it.IsAssignedToMyGroups ? "1" : "0")">
                                                <td>
                                                    <div class="date-value fw-semibold">@it.Categorie</div>
                                                    @if (!string.IsNullOrWhiteSpace(it.SousCategorie))
                                                    {
                                                        <div class="text-muted small">@it.SousCategorie</div>
                                                    }
                                                </td>
                                                <td>@it.Libelle</td>
                                                <td>
                                                    <span class="badge" style="background:#6c757d;color:#fff;">@($"P{it.Priorite}")</span>
                                                </td>
                                                <td>
                                                    <div>@it.DueDate.ToString("dd/MM/yyyy")</div>
                                                    @if (it.Source == "Calculée")
                                                    {
                                                        <div class="small text-muted">(calculée +@it.DelaiJours j)</div>
                                                    }
                                                    <div class="mt-1">
                                                        @if (!it.IsValidated)
                                                        {
                                                            if (it.DaysLeft > 0)
                                                            {
                                                                <span class="badge badge-info" style="background:#0dcaf0;color:#212529;"><i class="fas fa-arrow-right me-1"></i>Dans @it.DaysLeft j</span>
                                                            }
                                                            else if (it.DaysLeft == 0)
                                                            {
                                                                <span class="badge badge-warning" style="background:#ffc107;color:#212529;"><i class="fas fa-exclamation me-1"></i>Aujourd'hui</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-danger" style="background:#dc3545;color:#fff;"><i class="fas fa-clock me-1"></i>@Math.Abs(it.DaysLeft) j de retard</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="badge" style="background:#20c997;color:#fff;"><i class="fas fa-check me-1"></i>Validé</span>
                                                        }
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (it.IsValidated)
                                                    {
                                                        <div>
                                                            <span class="status-badge status-success">
                                                                <i class="fas fa-check-circle me-1"></i>
                                                                Validé
                                                            </span>
                                                            <div class="small text-muted mt-1">
                                                                le @(it.DateValidation?.ToString("dd/MM/yyyy")) par @(it.ValidePar ?? "-")
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge status-warning">
                                                            <i class="fas fa-clock me-1"></i>
                                                            En cours
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!it.IsValidated)
                                                    {
                                                        <form method="post" asp-page-handler="ValidateChecklist" class="d-inline">
                                                            <input type="hidden" name="checklistId" value="@it.Id" />
                                                            <button type="submit" class="btn btn-sm btn-success">
                                                                <i class="fas fa-check me-1"></i>Valider
                                                            </button>
                                                            @Html.AntiForgeryToken()
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="UnvalidateChecklist" class="d-inline">
                                                            <input type="hidden" name="checklistId" value="@it.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                                <i class="fas fa-undo me-1"></i>Annuler
                                                            </button>
                                                            @Html.AntiForgeryToken()
                                                        </form>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                groupIndex++;
            }

            <!-- Pagination serveur -->
            <nav class="mt-3">
                <ul class="pagination pagination-sm">
                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.PageNumber-1)&pageSize=@Model.PageSize" tabindex="-1">Précédent</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="?page=@i&pageSize=@Model.PageSize">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.PageNumber+1)&pageSize=@Model.PageSize">Suivant</a>
                    </li>
                </ul>
            </nav>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-tasks"></i>
                </div>
                <h4>Aucune checklist</h4>
                <p>Aucun élément de checklist n'a été trouvé.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Elements
            const filterButtons = document.querySelectorAll('.filter-btn');
            const searchInput = document.getElementById('searchInput');
            const filterPrsName = document.getElementById('filterPrsName');
            const filterPrsState = document.getElementById('filterPrsState');
            const dueSoonSlider = document.getElementById('dueSoonSlider');
            const dueSoonValue = document.getElementById('dueSoonValue');
            const quickFilters = document.querySelectorAll('.quick-filter');

            // Persisted UI state
            const LS_SORT_COL = 'milestones.sort.col';
            const LS_SORT_DIR = 'milestones.sort.dir';
            const LS_SORT_GROUPS = 'milestones.sort.groups';
            const LS_PRS = 'milestones.filter.prs';
            const LS_PRS_STATE = 'milestones.filter.prsstate';
            const LS_SEARCH = 'milestones.filter.search';
            const LS_DUE_SOON = 'milestones.dueSoonDays';
            const LS_QF = 'milestones.quickfilter';

            // Apply persisted filters
            if (localStorage.getItem(LS_PRS)) filterPrsName.value = localStorage.getItem(LS_PRS);
            if (localStorage.getItem(LS_PRS_STATE)) filterPrsState.value = localStorage.getItem(LS_PRS_STATE);
            if (localStorage.getItem(LS_SEARCH)) searchInput.value = localStorage.getItem(LS_SEARCH);
            if (localStorage.getItem(LS_DUE_SOON)) {
                dueSoonSlider.value = localStorage.getItem(LS_DUE_SOON);
                dueSoonValue.innerText = localStorage.getItem(LS_DUE_SOON);
            } else {
                dueSoonValue.innerText = dueSoonSlider.value;
            }

            // Handlers
            filterButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    filterButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });

            searchInput.addEventListener('input', function() {
                localStorage.setItem(LS_SEARCH, this.value || '');
                applyFilters();
            });

            if (filterPrsName) {
                filterPrsName.addEventListener('change', function() {
                    localStorage.setItem(LS_PRS, this.value || '');
                    applyFilters();
                });
            }
            if (filterPrsState) {
                filterPrsState.addEventListener('change', function() {
                    localStorage.setItem(LS_PRS_STATE, this.value || 'all');
                    applyFilters();
                });
            }

            dueSoonSlider.addEventListener('input', function() {
                dueSoonValue.innerText = this.value;
                localStorage.setItem(LS_DUE_SOON, this.value);
                applyFilters();
            });

            quickFilters.forEach(btn => {
                btn.addEventListener('click', function() {
                    // toggle-like behavior (one at a time)
                    if (this.classList.contains('active')) {
                        this.classList.remove('active');
                        localStorage.removeItem(LS_QF);
                    } else {
                        quickFilters.forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                        localStorage.setItem(LS_QF, this.dataset.qf);
                    }
                    applyFilters();
                });
            });

            // Sorting (persisted)
            document.querySelectorAll('.checklist-table thead th.sortable').forEach(th => {
                th.addEventListener('click', function() {
                    const key = this.getAttribute('data-sort-key');
                    let dir = localStorage.getItem(LS_SORT_DIR) || 'asc';
                    const current = localStorage.getItem(LS_SORT_COL);
                    if (current === key) {
                        dir = (dir === 'asc') ? 'desc' : 'asc';
                    } else {
                        dir = 'asc';
                    }
                    localStorage.setItem(LS_SORT_COL, key);
                    localStorage.setItem(LS_SORT_DIR, dir);
                    sortAllGroups(key, dir);
                });
            });

            // Sort groups by PRS title (button on header title itself not provided, but keep API by localStorage flag)
            const prsContainer = document.getElementById('prsContainer');
            if (localStorage.getItem(LS_SORT_GROUPS)) {
                prsContainer.setAttribute('data-sort-groups', localStorage.getItem(LS_SORT_GROUPS));
            }
            // (Optional) You can add a button to toggle group sorting if needed

            function sortAllGroups(key, dir) {
                document.querySelectorAll('.checklist-table').forEach(tbl => sortTableBody(tbl, key, dir));
            }

            function sortTableBody(table, key, dir) {
                const tbody = table.querySelector('tbody');
                const rows = Array.from(tbody.querySelectorAll('.checklist-row'));

                const factor = dir === 'asc' ? 1 : -1;
                const collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });

                rows.sort((a, b) => {
                    switch (key) {
                        case 'categorie':
                            return factor * collator.compare(a.querySelector('td').innerText.trim(), b.querySelector('td').innerText.trim());
                        case 'libelle':
                            return factor * collator.compare(a.children[1].innerText.trim(), b.children[1].innerText.trim());
                        case 'priorite':
                            return factor * ((parseInt(a.dataset.priority || '0') - parseInt(b.dataset.priority || '0')));
                        case 'due':
                            return factor * ((parseInt(a.dataset.dueticks || '0') - parseInt(b.dataset.dueticks || '0')));
                        case 'statut':
                            return factor * collator.compare(a.dataset.status, b.dataset.status);
                        default:
                            return 0;
                    }
                });

                rows.forEach(r => tbody.appendChild(r));
            }

            function applyFilters() {
                const statusFilter = document.querySelector('.filter-btn.active').getAttribute('data-filter');
                const searchText = (searchInput.value || '').toLowerCase();
                const prsValue = (filterPrsName && filterPrsName.value) ? filterPrsName.value : '';
                const prsStateValue = (filterPrsState && filterPrsState.value) ? filterPrsState.value : 'all';
                const dueSoonDays = parseInt(dueSoonSlider.value || '3', 10);
                const quick = localStorage.getItem(LS_QF) || '';

                // Filter groups (PRS) by PRS name/state; then filter rows inside
                const groups = document.querySelectorAll('.prs-group');
                groups.forEach(group => {
                    const grpTitle = group.getAttribute('data-prs-title') || '';
                    const grpState = group.getAttribute('data-prsstate') || 'autre';

                    const groupMatchesPrsName = prsValue === '' || grpTitle === prsValue;
                    const groupMatchesPrsState = prsStateValue === 'all' || grpState === prsStateValue;

                    // For each row apply filters
                    const rows = group.querySelectorAll('.checklist-row');
                    let anyVisible = false;
                    rows.forEach(row => {
                        const status = row.getAttribute('data-status');
                        const searchable = (row.getAttribute('data-searchable') || '').toLowerCase();
                        const daysLeft = parseInt(row.getAttribute('data-daysleft') || '0', 10);
                        const me = row.getAttribute('data-assignee-me') === '1';
                        const grp = row.getAttribute('data-assignee-group') === '1';

                        // Item-level filters
                        const matchesStatus = statusFilter === 'all' || status === statusFilter;
                        const matchesSearch = searchText === '' || searchable.includes(searchText);

                        // Quick filters
                        let matchesQuick = true;
                        if (quick === 'me') matchesQuick = me;
                        else if (quick === 'groups') matchesQuick = grp;
                        else if (quick === 'late') matchesQuick = (status === 'retard');
                        else if (quick === 'today') matchesQuick = (!row.dataset.status || row.dataset.status !== 'valide') && daysLeft === 0;

                        // DueSoon: if status "encours" and daysLeft within threshold, keep; otherwise, if other status selected, ignore this slider
                        // Here we apply dueSoon as an additional filter only if user selected "encours" - but request is "appliqué au filtre proche"
                        // So we do: when statusFilter == 'encours', only keep rows with 0 <= daysLeft <= dueSoonDays
                        let matchesDueSoon = true;
                        if (statusFilter === 'encours') {
                            matchesDueSoon = !isNaN(daysLeft) && daysLeft >= 0 && daysLeft <= dueSoonDays;
                        }

                        const visible = groupMatchesPrsName && groupMatchesPrsState && matchesStatus && matchesSearch && matchesQuick && matchesDueSoon;

                        row.style.display = visible ? '' : 'none';
                        if (visible) anyVisible = true;
                    });

                    // Show or hide entire group if no visible rows or PRS-level filters fail
                    group.style.display = (anyVisible && groupMatchesPrsName && groupMatchesPrsState) ? '' : 'none';
                });

                // Sorting persistence after filtering (keep current sort)
                const key = localStorage.getItem(LS_SORT_COL);
                const dir = localStorage.getItem(LS_SORT_DIR) || 'asc';
                if (key) sortAllGroups(key, dir);
            }

            // Initial apply
            applyFilters();

            // Restore sort from localStorage
            const initSortCol = localStorage.getItem(LS_SORT_COL);
            const initSortDir = localStorage.getItem(LS_SORT_DIR) || 'asc';
            if (initSortCol) {
                sortAllGroups(initSortCol, initSortDir);
            }
        });
    </script>

    <style>
        /* Variables CSS pour la cohérence */
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --success-gradient: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            --warning-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --info-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --danger-gradient: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%);
            --glass-bg: rgba(255, 255, 255, 0.95);
            --glass-border: rgba(255, 255, 255, 0.2);
            --shadow-soft: 0 8px 32px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 12px 40px rgba(0, 0, 0, 0.15);
            --border-radius: 1rem;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Container principal */
        .milestones-container {
            animation: slideInUp 0.6s ease-out;
        }

        @@keyframes slideInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* En-tête */
        .milestones-header {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--border-radius);
            padding: 2rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow-soft);
        }

        .page-title {
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 800;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-weight: 500;
            margin-bottom: 0;
        }

        /* Stats */
        .stats-summary {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .stat-badge {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
            border: 1px solid var(--glass-border);
            transition: var(--transition);
            min-width: 80px;
        }
        .stat-badge:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); }
        .stat-badge i { font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }
        .stat-badge span { font-size: 1.8rem; font-weight: 800; display: block; margin-bottom: 0.25rem; }
        .stat-badge small { font-weight: 600; opacity: 0.8; }

        .stat-total { color: #495057; }
        .stat-success { color: #28a745; }
        .stat-warning { color: #ffc107; }
        .stat-danger { color: #dc3545; }

        /* Panneau d'actions */
        .actions-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            box-shadow: var(--shadow-soft);
        }

        .filter-label { font-weight: 700; color: #495057; margin-bottom: 0.5rem; }
        .filter-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
        .filter-btn {
            background: white; border: 2px solid #e9ecef; border-radius: 8px; padding: 0.5rem 1rem;
            cursor: pointer; font-weight: 600; transition: var(--transition); display: flex; align-items: center; gap: 0.5rem;
        }
        .filter-btn:hover { border-color: #667eea; transform: translateY(-2px); }
        .filter-btn.active { background: var(--primary-gradient); border-color: #667eea; color: white; }

        .search-box { position: relative; display: flex; align-items: center; }
        .search-box i { position: absolute; left: 1rem; color: #6c757d; z-index: 2; }
        .search-box input {
            background: white; border: 2px solid #e9ecef; border-radius: 25px; padding: 0.75rem 1rem 0.75rem 3rem;
            font-weight: 500; transition: var(--transition); width: 300px;
        }
        .search-box input:focus { border-color: #667eea; box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25); outline: none; }

        /* Accordions */
        .accordion-item.prs-group { border: 1px solid #e9ecef; border-radius: 12px; overflow: hidden; }
        .accordion-button { padding: 1rem; }
        .accordion-button:not(.collapsed) { background-color: #f8f9fa; }

        /* Tables */
        .table { margin: 0; background: transparent; }
        .table thead th { cursor: default; }
        .table thead th.sortable { cursor: pointer; user-select: none; }
        .table thead th.sortable:hover { text-decoration: underline; }

        .checklist-row { transition: var(--transition); border: none; }
        .checklist-row:hover { background: rgba(102, 126, 234, 0.05); transform: translateX(5px); }
        .checklist-row td {
            padding: 0.9rem 0.75rem; border: none; border-bottom: 1px solid rgba(0,0,0,0.05);
            vertical-align: middle;
        }

        .status-badge {
            padding: 0.35rem 0.7rem; border-radius: 16px; font-weight: 600; font-size: 0.82rem; display: inline-flex; align-items: center; gap: 0.4rem;
        }
        .status-success { background: var(--success-gradient); color: white; }
        .status-warning { background: var(--warning-gradient); color: white; }
        .status-danger { background: var(--danger-gradient); color: white; }

        /* Pagination */
        .pagination .page-link { color: #495057; }
        .pagination .page-item.active .page-link { background-color: #667eea; border-color: #667eea; }

        /* Empty state */
        .empty-state { text-align: center; padding: 4rem 2rem; color: #6c757d; }
        .empty-icon { font-size: 4rem; margin-bottom: 1rem; opacity: 0.5; }
        .empty-state h4 { margin-bottom: 1rem; color: #495057; }

        /* Responsive */
        @@media (max-width: 768px) {
            .milestones-header, .actions-panel { padding: 1rem; }
            .stats-summary { justify-content: center; }
            .actions-panel { flex-direction: column; align-items: stretch; }
            .search-box input { width: 100%; }
            .checklist-row:hover { transform: none; }
        }

        @@keyframes slideInUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}