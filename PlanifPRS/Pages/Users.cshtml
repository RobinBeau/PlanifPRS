@page
@model PlanifPRS.Pages.UsersModel
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<h1>Gestion des utilisateurs</h1>

@if (Model.IsAdmin)
{
    <div class="mb-3">
        <input type="text" id="searchInput" class="form-control" placeholder="Rechercher par nom, prénom, login, mail, service ou droits..." />
    </div>

    <div class="mb-3">
        <small class="text-muted">
            <strong>Légende des droits :</strong>
            <span class="badge bg-danger ms-2 role-filter" data-role="admin" style="cursor: pointer;">Admin</span> Accès complet
            <span class="badge bg-primary ms-2 role-filter" data-role="cdp" style="cursor: pointer;">CDP/Pilote</span> Gestion projets
            <span class="badge bg-warning ms-2 role-filter" data-role="validateur" style="cursor: pointer;">Validateur</span> Validation PRS
            <span class="badge bg-success ms-2 role-filter" data-role="process" style="cursor: pointer;">Process</span> Process / Equipements Indus
            <span class="badge bg-orange ms-2 role-filter" data-role="maintenance" style="background-color: #fd7e14; cursor: pointer;">Maintenance</span> Maintenance
            <span class="badge bg-purple ms-2 role-filter" data-role="qualite" style="background-color: #6f42c1; cursor: pointer;">Qualité</span> Qualité
            <span class="badge bg-secondary ms-2 role-filter" data-role="visualiseur" style="cursor: pointer;">Visualiseur</span> Lecture seule
        </small>
    </div>

    <table class="table table-bordered table-striped mt-2" id="usersTable">
        <thead class="thead-dark">
            <tr>
                <th class="sortable" data-column="0">ID <span class="sort-icon">↕️</span></th>
                <th class="sortable" data-column="1">Matricule <span class="sort-icon">↕️</span></th>
                <th class="sortable sorted-asc" data-column="2">Nom <span class="sort-icon">↑</span></th>
                <th class="sortable" data-column="3">Prénom <span class="sort-icon">↕️</span></th>
                <th class="sortable" data-column="4">Login Windows <span class="sort-icon">↕️</span></th>
                <th class="sortable" data-column="5">Mail <span class="sort-icon">↕️</span></th>
                <th class="sortable" data-column="6">Service <span class="sort-icon">↕️</span></th>
                <th style="min-width: 180px;">Droits</th>
            </tr>
        </thead>
        <tbody id="userTableBody">
            @foreach (var user in Model.ListeUtilisateurs)
            {
                <tr class="user-row"
                    data-search="@($"{user.Id} {user.Matricule} {user.Nom} {user.Prenom} {user.LoginWindows} {user.Mail} {user.Service} {user.Droits}".ToLower())"
                    data-role="@((user.Droits ?? "visualiseur").ToLower())">
                    <td>@user.Id</td>
                    <td>@user.Matricule</td>
                    <td>@user.Nom</td>
                    <td>@user.Prenom</td>
                    <td>@user.LoginWindows</td>
                    <td>@user.Mail</td>
                    <td>@user.Service</td>
                    <td style="min-width: 180px;">
                        <form method="post" asp-page-handler="UpdateDroit" class="m-0 p-0">
                            <input type="hidden" name="id" value="@user.Id" />
                            <select name="nouveauDroit" class="form-select form-select-sm" onchange="this.form.submit()">
                                @{
                                    var droits = user.Droits ?? "Visualiseur";
                                }
                                <option value="admin" selected="@(droits.ToLower() == "admin")">🔴 Admin</option>
                                <option value="cdp" selected="@(droits.ToLower() == "cdp")">🔵 CDP / Pilote</option>
                                <option value="validateur" selected="@(droits.ToLower() == "validateur")">🟡 Validateur</option>
                                <option value="process" selected="@(droits.ToLower() == "process")">🟢 Process</option>
                                <option value="maintenance" selected="@(droits.ToLower() == "maintenance")">🟠 Maintenance</option>
                                <option value="qualite" selected="@(droits.ToLower() == "qualite")">🟣 Qualité</option>
                                <option value="visualiseur" selected="@(droits.ToLower() == "visualiseur")">⚫ Visualiseur</option>
                            </select>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📊 Statistiques des droits</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    @{
                        var stats = Model.ListeUtilisateurs
                        .GroupBy(u => u.Droits?.ToLower() ?? "visualiseur")
                        .ToDictionary(g => g.Key, g => g.Count());
                    }
                    <div class="col-md-2">
                        <span class="badge bg-danger fs-6">@(stats.GetValueOrDefault("admin", 0))</span>
                        <br><small>Admin</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge bg-primary fs-6">@(stats.GetValueOrDefault("cdp", 0))</span>
                        <br><small>CDP/Pilote</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge bg-warning fs-6">@(stats.GetValueOrDefault("validateur", 0))</span>
                        <br><small>Validateur</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge bg-success fs-6">@(stats.GetValueOrDefault("process", 0))</span>
                        <br><small>Process</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge fs-6" style="background-color: #fd7e14;">@(stats.GetValueOrDefault("maintenance", 0))</span>
                        <br><small>Maintenance</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge fs-6" style="background-color: #6f42c1;">@(stats.GetValueOrDefault("qualite", 0))</span>
                        <br><small>Qualité</small>
                    </div>
                    <div class="col-md-2">
                        <span class="badge bg-secondary fs-6">@(stats.GetValueOrDefault("visualiseur", 0))</span>
                        <br><small>Visualiseur</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .sortable {
        cursor: pointer;
        user-select: none;
    }

        .sortable:hover {
            background-color: #f8f9fa;
        }

    .sort-icon {
        font-size: 0.8em;
        margin-left: 5px;
    }

    .sorted-asc .sort-icon {
        color: #28a745;
    }

    .sorted-desc .sort-icon {
        color: #dc3545;
    }

    .role-filter.active {
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.5);
        transform: scale(1.1);
    }

    .role-filter:hover {
        transform: scale(1.05);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const userRows = document.querySelectorAll('.user-row');
        const table = document.getElementById('usersTable');
        const tbody = document.getElementById('userTableBody');
        const roleFilters = document.querySelectorAll('.role-filter');

        let activeRoleFilter = null;

        // Fonction de recherche
        searchInput.addEventListener('input', function() {
            filterUsers();
        });

        // Fonction de filtrage par rôle
        roleFilters.forEach(function(badge) {
            badge.addEventListener('click', function() {
                const role = this.getAttribute('data-role');

                // Si on clique sur le même rôle, on désactive le filtre
                if (activeRoleFilter === role) {
                    activeRoleFilter = null;
                    this.classList.remove('active');
                } else {
                    // Désactiver l'ancien filtre
                    roleFilters.forEach(b => b.classList.remove('active'));

                    // Activer le nouveau filtre
                    activeRoleFilter = role;
                    this.classList.add('active');
                }

                filterUsers();
            });
        });

        function filterUsers() {
            const searchTerm = searchInput.value.toLowerCase().trim();

            userRows.forEach(function(row) {
                const searchData = row.getAttribute('data-search');
                const userRole = row.getAttribute('data-role');

                let showRow = true;

                // Filtre par texte de recherche
                if (searchTerm && !searchData.includes(searchTerm)) {
                    showRow = false;
                }

                // Filtre par rôle
                if (activeRoleFilter && userRole !== activeRoleFilter) {
                    showRow = false;
                }

                row.style.display = showRow ? '' : 'none';
            });
        }

        // Fonction de tri
        let currentSort = { column: 2, direction: 'asc' }; // Par défaut sur la colonne Nom (index 2)

        table.addEventListener('click', function(e) {
            if (e.target.closest('.sortable')) {
                const th = e.target.closest('.sortable');
                const columnIndex = parseInt(th.getAttribute('data-column'));

                // Déterminer la direction du tri
                let direction = 'asc';
                if (currentSort.column === columnIndex && currentSort.direction === 'asc') {
                    direction = 'desc';
                }

                // Mettre à jour les classes CSS
                document.querySelectorAll('.sortable').forEach(header => {
                    header.classList.remove('sorted-asc', 'sorted-desc');
                    header.querySelector('.sort-icon').textContent = '↕️';
                });

                th.classList.add(direction === 'asc' ? 'sorted-asc' : 'sorted-desc');
                th.querySelector('.sort-icon').textContent = direction === 'asc' ? '↑' : '↓';

                // Effectuer le tri
                sortTable(columnIndex, direction);
                currentSort = { column: columnIndex, direction: direction };
            }
        });

        function sortTable(columnIndex, direction) {
            const rows = Array.from(tbody.querySelectorAll('tr.user-row'));

            rows.sort((a, b) => {
                let aVal = a.cells[columnIndex].textContent.trim();
                let bVal = b.cells[columnIndex].textContent.trim();

                // Si c'est la colonne ID, traiter comme des nombres
                if (columnIndex === 0) {
                    aVal = parseInt(aVal);
                    bVal = parseInt(bVal);
                }

                let comparison = 0;
                if (typeof aVal === 'number' && typeof bVal === 'number') {
                    comparison = aVal - bVal;
                } else {
                    comparison = aVal.localeCompare(bVal, 'fr', { numeric: true, sensitivity: 'base' });
                }

                return direction === 'asc' ? comparison : -comparison;
            });

            // Réorganiser les lignes dans le DOM
            rows.forEach(row => tbody.appendChild(row));
        }
    });
</script>