@page
@model PlanifPRS.Pages.DashboardModel
@{
    ViewData["Title"] = "Mon tableau de bord";
    var today = DateTime.Today;
}

<div class="dashboard-container">
    <div class="header d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="page-title">
                <i class="fas fa-chart-line me-2"></i>Tableau de bord
            </h1>
            <div class="text-muted">
                Bonjour @Model.CurrentUserLogin • Rôle: @Model.CurrentUserRole
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-bell text-muted"></i>
                <span>Échéance proche (jours)</span>
                <input type="range" id="dueSoonSlider" min="1" max="14" value="@Model.DefaultDueSoonDays" />
                <span id="dueSoonValue" class="badge bg-secondary">@Model.DefaultDueSoonDays</span>
            </div>
            <a class="btn btn-outline-primary btn-sm" href="/Milestones">
                <i class="fas fa-list-check me-1"></i>Voir toutes les checklists
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Flash))
    {
        <div class="alert alert-success">@Model.Flash</div>
    }

    @if (Model.ParentChildAlerts.Any())
    {
        <div class="alert alert-danger shadow-sm mb-3">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <i class="fas fa-link-slash me-2"></i>
                    <strong>Conflits PRS parent/enfant détectés:</strong> @Model.ParentChildAlerts.Count
                    <div class="small text-muted">Certaines PRS "Finition" démarrent avant la fin de leur PRS "CMS" parente.</div>
                </div>
                <a href="/Index" class="btn btn-sm btn-outline-light"><i class="fas fa-arrow-right me-1"></i>Voir le planning</a>
            </div>
            <ul class="mt-2 mb-0 small">
                @foreach (var c in Model.ParentChildAlerts.Take(5))
                {
                    <li>
                        Enfant #@c.EnfantId "@c.EnfantTitre" (début @c.EnfantDateDebut.ToString("dd/MM/yyyy HH:mm"))
                        avant fin parent #@c.ParentId "@c.ParentTitre" (@c.ParentDateFin.ToString("dd/MM/yyyy HH:mm"))
                    </li>
                }
            </ul>
            @if (Model.ParentChildAlerts.Count > 5)
            {
                <div class="small text-muted mt-1">… et @(Model.ParentChildAlerts.Count - 5) autres</div>
            }
        </div>
    }

    @if (Model.PrsAbsenceAlerts != null && Model.PrsAbsenceAlerts.Any())
    {
        <div class="alert alert-warning shadow-sm mb-3">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <i class="fas fa-user-slash me-2"></i>
                    <strong>PRS avec intervenants absents :</strong> @Model.PrsAbsenceAlerts.Count
                    <div class="small text-muted">
                        Ressources (Out Of Office) détectées sur l’horizon.
                    </div>
                </div>
                <a href="/Index" class="btn btn-sm btn-outline-dark">
                    <i class="fas fa-arrow-right me-1"></i>Planning
                </a>
            </div>
            <ul class="mt-2 mb-0 small">
                @foreach (var a in Model.PrsAbsenceAlerts.Take(8))
                {
                    <li>
                        #@a.PrsId "@a.Titre"
                        (@a.DateDebut.ToString("dd/MM HH:mm") → @a.DateFin.ToString("dd/MM HH:mm"))
                        : <span class="text-danger fw-semibold">@string.Join(", ", a.AbsentLogins)</span>
                    </li>
                }
            </ul>
            @if (Model.PrsAbsenceAlerts.Count > 8)
            {
                <div class="small text-muted mt-1">… et @(Model.PrsAbsenceAlerts.Count - 8) autres</div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary small py-2 mb-3">
            <i class="fas fa-user-check me-1"></i>Aucune absence détectée sur les PRS en cours ou dans les 30 jours.
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card kpi-card shadow-sm">
                <div class="card-body">
                    <div class="kpi-title text-muted">Mes éléments ouverts</div>
                    <div class="kpi-value">@Model.Summary.TotalOpenItems</div>
                    <div class="kpi-sub text-muted">Checklist non validées</div>
                </div>
                <div class="kpi-icon"><i class="fas fa-tasks"></i></div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card kpi-card shadow-sm">
                <div class="card-body">
                    <div class="kpi-title text-muted">En retard</div>
                    <div class="kpi-value text-danger">@Model.Summary.LateCount</div>
                    <div class="kpi-sub text-muted">Échéance dépassée</div>
                </div>
                <div class="kpi-icon text-danger"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card kpi-card shadow-sm">
                <div class="card-body">
                    <div class="kpi-title text-muted">Aujourd'hui</div>
                    <div class="kpi-value text-warning">@Model.Summary.TodayCount</div>
                    <div class="kpi-sub text-muted">À valider aujourd'hui</div>
                </div>
                <div class="kpi-icon text-warning"><i class="fas fa-calendar-day"></i></div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card kpi-card shadow-sm">
                <div class="card-body">
                    <div class="kpi-title text-muted">Prochaines @Model.DefaultDueSoonDays j</div>
                    <div class="kpi-value text-info" id="kpiSoonValue">@Model.Summary.DueSoonCount</div>
                    <div class="kpi-sub text-muted">Échéance proche</div>
                </div>
                <div class="kpi-icon text-info"><i class="fas fa-hourglass-half"></i></div>
            </div>
        </div>
    </div>

    @if (Model.IsManagerView)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-3">
                <div class="card admin-card shadow-sm">
                    <div class="card-body">
                        <div class="text-muted fw-semibold mb-2"><i class="fas fa-gauge-high me-1"></i>Vue globale</div>
                        <div class="d-flex justify-content-between small">
                            <span>PRS totales</span><span class="fw-bold">@Model.AdminSummary.TotalPrs</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>PRS "En attente"</span><span class="fw-bold">@Model.AdminSummary.PrsEnAttente</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>PRS "À re-valider"</span><span class="fw-bold">@Model.AdminSummary.PrsAReValider</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>PRS validées</span><span class="fw-bold">@Model.AdminSummary.PrsValidees</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>Utilisateurs actifs</span><span class="fw-bold">@Model.AdminSummary.UsersActifs</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>Groupes actifs</span><span class="fw-bold">@Model.AdminSummary.GroupesActifs</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-9">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="fw-semibold text-muted">
                                <i class="fas fa-clipboard-list me-1"></i>PRS en attente / à re-valider
                            </div>
                            <a href="/Index" class="btn btn-sm btn-outline-primary"><i class="fas fa-arrow-right"></i></a>
                        </div>
                        @if (Model.AdminSummary.PrsEnAttenteList.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>PRS</th>
                                            <th>Début</th>
                                            <th>Fin</th>
                                            <th>Créée par</th>
                                            <th>Dernière modif</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in Model.AdminSummary.PrsEnAttenteList)
                                        {
                                            <tr>
                                                <td>
                                                    @p.Titre
                                                    @if (p.Statut == "En attente")
                                                    {
                                                        <span class="badge bg-warning text-dark ms-1">En attente</span>
                                                    }
                                                    else if (p.Statut == "À re-valider")
                                                    {
                                                        <span class="badge bg-danger ms-1">À re-valider</span>
                                                    }
                                                </td>
                                                <td>@p.DateDebut.ToString("dd/MM/yyyy")</td>
                                                <td>@p.DateFin.ToString("dd/MM/yyyy")</td>
                                                <td>@p.CreatedBy</td>
                                                <td>@p.DerniereModification.ToString("dd/MM/yyyy HH:mm")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small">Aucune PRS en attente ou à re-valider.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-semibold text-muted"><i class="fas fa-triangle-exclamation me-1"></i>En retard (qui me concernent)</div>
                        <a href="/Milestones" class="btn btn-sm btn-outline-secondary"><i class="fas fa-list me-1"></i>Tout voir</a>
                    </div>
                    @if (Model.OverdueItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>PRS</th>
                                        <th>Élément</th>
                                        <th>Échéance</th>
                                        <th>Retard</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var it in Model.OverdueItems)
                                    {
                                        <tr>
                                            <td>@it.PrsTitre</td>
                                            <td>
                                                <div>@it.Libelle</div>
                                                <div class="small text-muted">
                                                    @it.Categorie @if (!string.IsNullOrWhiteSpace(it.SousCategorie))
                                                    {
                                                        <text>• @it.SousCategorie</text>
                                                    }
                                                </div>
                                            </td>
                                            <td>@it.DueDate.ToString("dd/MM/yyyy")</td>
                                            <td><span class="badge bg-danger">@Math.Abs(it.DaysLeft) j</span></td>
                                            <td>
                                                <form method="post" asp-page-handler="ValidateChecklist" class="d-inline">
                                                    <input type="hidden" name="checklistId" value="@it.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check me-1"></i>Valider</button>
                                                    @Html.AntiForgeryToken()
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">Aucun élément en retard.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-semibold text-muted"><i class="fas fa-bullseye me-1"></i>Prochaines échéances (qui me concernent)</div>
                        <div>
                            <span class="badge bg-info"><i class="fas fa-bell me-1"></i><span id="soonCount">@Model.DueSoonItems.Count</span> à venir</span>
                        </div>
                    </div>

                    @if (Model.DueSoonItems.Any())
                    {
                        <ul class="list-group list-group-flush" id="soonList">
                            @foreach (var it in Model.DueSoonItems)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center soon-item"
                                    data-daysleft="@it.DaysLeft">
                                    <div class="me-3">
                                        <div class="fw-semibold">@it.Libelle</div>
                                        <div class="small text-muted">
                                            @it.PrsTitre • @it.Categorie @if (!string.IsNullOrWhiteSpace(it.SousCategorie))
                                            {
                                                <text>• @it.SousCategorie</text>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small">Échéance: <strong>@it.DueDate.ToString("dd/MM/yyyy")</strong></div>
                                        <div>
                                            <span class="badge bg-@(it.DaysLeft == 0 ? "warning text-dark" : "info")">
                                                @(it.DaysLeft == 0 ? "Aujourd'hui" : $"Dans {it.DaysLeft} j")
                                            </span>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted small">Aucun élément à échéance proche.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-semibold text-muted"><i class="fas fa-calendar-alt me-1"></i>PRS à venir (qui me concernent)</div>
                        <a href="/Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-right"></i></a>
                    </div>
                    @if (Model.UpcomingPrs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>PRS</th>
                                        <th>Statut</th>
                                        <th>Début</th>
                                        <th>Fin</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.UpcomingPrs)
                                    {
                                        var absenceAlert = Model.PrsAbsenceAlerts?.FirstOrDefault(a => a.PrsId == p.Id);
                                        var absenceTitle = absenceAlert != null
                                        ? "Absents: " + string.Join(", ", absenceAlert.AbsentLogins ?? new List<string>())
                                        : string.Empty;

                                        <tr>
                                            <td>
                                                @p.Titre
                                                @if (absenceAlert != null)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1" title="@absenceTitle">
                                                        <i class="fas fa-user-slash"></i>
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (p.Statut == "Validé")
                                                {
                                                    <span class="badge bg-success">Validé</span>
                                                }
                                                else if (p.Statut == "À re-valider")
                                                {
                                                    <span class="badge bg-danger">À re-valider</span>
                                                }
                                                else if (p.Statut == "En attente")
                                                {
                                                    <span class="badge bg-warning text-dark">En attente</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@p.Statut</span>
                                                }
                                            </td>
                                            <td>@p.DateDebut.ToString("dd/MM/yyyy")</td>
                                            <td>@p.DateFin.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">Aucune PRS à venir.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="fw-semibold text-muted"><i class="fas fa-clock-rotate-left me-1"></i>Activité récente PRS</div>
                        <a href="/Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-right"></i></a>
                    </div>
                    @if (Model.RecentPrs.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var a in Model.RecentPrs)
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    <div>
                                        <div class="fw-semibold">@a.Titre</div>
                                        <div class="small text-muted">Statut: @a.Statut • Créée par @a.CreatedBy</div>
                                    </div>
                                    <div class="text-end small text-muted">
                                        Modifiée le @a.DerniereModification.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted small">Aucune activité récente.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const slider = document.getElementById('dueSoonSlider');
            const value = document.getElementById('dueSoonValue');
            const soonList = document.getElementById('soonList');
            const soonCount = document.getElementById('soonCount');
            const kpiSoonValue = document.getElementById('kpiSoonValue');

            function applySoonFilter() {
                const maxDays = parseInt(slider.value || '7', 10);
                value.innerText = maxDays;
                let count = 0;
                if (!soonList) return;
                soonList.querySelectorAll('.soon-item').forEach(li => {
                    const dl = parseInt(li.getAttribute('data-daysleft') || '0', 10);
                    const show = !isNaN(dl) && dl >= 0 && dl <= maxDays;
                    li.style.display = show ? '' : 'none';
                    if (show) count++;
                });
                if (soonCount) soonCount.innerText = count;
                if (kpiSoonValue) kpiSoonValue.innerText = count;
                try { localStorage.setItem('dashboard.dueSoonDays', maxDays.toString()); } catch { }
            }

            slider.addEventListener('input', applySoonFilter);

            try {
                const saved = localStorage.getItem('dashboard.dueSoonDays');
                if (saved) {
                    slider.value = saved;
                    value.innerText = saved;
                }
            } catch { }

            applySoonFilter();
        });
    </script>

    <style>
        .page-title {
            font-weight: 800;
            margin: 0;
        }

        .kpi-card {
            position: relative;
            overflow: hidden;
            border: 1px solid #f0f0f0;
        }

        .kpi-title {
            font-size: .9rem;
        }

        .kpi-value {
            font-size: 1.8rem;
            font-weight: 800;
        }

        .kpi-sub {
            font-size: .8rem;
        }

        .kpi-icon {
            position: absolute;
            bottom: .75rem;
            right: .75rem;
            font-size: 1.5rem;
            opacity: .25;
        }

        .admin-card {
            border: 1px solid #f0f0f0;
        }

        .dashboard-container .card {
            border-radius: .75rem;
        }

        .list-group-item {
            border-color: #f0f0f0;
        }
    </style>
}