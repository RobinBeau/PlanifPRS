    if (typeof window.__prsRefreshAbsences === 'function') window.__prsRefreshAbsences();
}

// Seed des affectations EXISTANTES (rendu serveur) au chargement + retry court
(function seedAssignedFromExisting() {
    // Normalisation pour matcher "Prenom Nom" vs "Nom Prenom", accents, etc.
    const norm = (s) => (s || '')
        .normalize('NFD')
        .replace(/\p{Diacritic}/gu, '')
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();

    const reverseMatch = (src, tgt) => {
        const parts = tgt.split(' ');
        if (parts.length < 2) return false;
        const rev = (parts[1] + ' ' + parts[0]).trim();
        return src === rev || src.includes(rev);
    };

    assignedExisting = [];
    const lis = document.querySelectorAll('#affectationsList li[data-existing="true"]');
    const userOptions = Array.from(document.querySelectorAll('#userSelect option[value]'));

    lis.forEach(li => {
        const type = li.dataset.type || 'Utilisateur';
        const nameText = (li.querySelector('span.me-auto')?.childNodes[0]?.nodeValue || '').trim();
        const infoText = (li.querySelector('span.me-auto .text-muted')?.textContent || '').replace(/[()]/g, '').trim();

        let email = (li.dataset.email || '').trim();
        let id = 0;

        if (type === 'Utilisateur') {
            if (!email) {
                const target = norm(nameText);
                const opt = userOptions.find(o => {
                    const dn = norm(o.dataset.name || '');
                    const tt = norm(o.textContent || '');
                    return (
                        dn === target ||
                        tt.includes(target) ||
                        reverseMatch(dn, target) ||
                        reverseMatch(tt, target)
                    );
                });
                if (opt) {
                    email = (opt.getAttribute('data-email') || '').trim();
                    id = parseInt(opt.value || '0', 10) || 0;
                }
            }
        }

        assignedExisting.push({ id, type, name: nameText, info: infoText, email });
    });

    // 1) synchro immédiate
    renderAffectationsForCalendar();

    // 2) retry court pour attendre _CalendarBlock si nécessaire
    let tries = 0;
    const maxTries = 50; // ~5s
    const timer = setInterval(() => {
        const ready = typeof window.__prsRefreshAbsences === 'function';
        if (ready) {
            renderAffectationsForCalendar();
            clearInterval(timer);
            return;
        }
        if (++tries >= maxTries) clearInterval(timer);
    }, 100);
})();

