@page "{id:int}"
@model PlanifPRS.Pages.CloneModel
@{
    ViewData["Title"] = "Cloner une PRS";

    var canEdit = Model.CanEditPrs;
    var isAdminOrValidateur = Model.IsAdminOrValidateur;
    var isCreator = !string.IsNullOrEmpty(Model.Prs.CreatedByLogin) &&
                   Model.Prs.CreatedByLogin.Equals(Model.CurrentUserLogin, StringComparison.OrdinalIgnoreCase);
    var hasChecklist = Model.HasExistingChecklist;
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-prs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/edit-prs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/robia.css" asp-append-version="true" />

    <style>
        /* Surlignage vert de la suggestion sélectionnée (parité avec Edit) */
        #robia-suggestions .list-group-item.active {
            background-color: #f3fff6 !important; /* vert très clair */
            border-color: #198754 !important; /* vert bootstrap */
            color: #0f5132 !important; /* texte vert foncé */
        }

            #robia-suggestions .list-group-item.active .badge {
                background-color: #d1e7dd !important; /* badge assorti */
                color: #0f5132 !important;
            }
    </style>
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-edit"></i> @ViewData["Title"] #@Model.Prs.Id</h1>
        <p class="page-subtitle">
            <i class="fas fa-info-circle me-1"></i>
            @(canEdit ? "Modifiez les détails de votre planification existante" : "Consultation en lecture seule")
        </p>
        <div class="d-flex flex-wrap align-items-center mt-2">
            @if (isAdminOrValidateur)
            {
                <span class="badge bg-primary me-2"><i class="fas fa-user-shield"></i> Admin/Validateur</span>
            }
            @if (isCreator)
            {
                <span class="badge bg-success me-2"><i class="fas fa-user-edit"></i> Créateur</span>
            }
            <span class="badge @(canEdit ? "bg-success" : "bg-warning") me-2">
                <i class="fas @(canEdit ? "fa-check-circle" : "fa-eye")"></i> @(canEdit ? "Modification autorisée" : "Lecture seule")
            </span>
        </div>
        @if (!string.IsNullOrEmpty(Model.Prs.CreatedByLogin))
        {
            <div class="creator-badge mt-2">
                <i class="fas fa-user-edit"></i>
                <span>Créée par : <strong>@Model.Prs.CreatedByLogin</strong></span>
                <span class="ms-2 text-muted">(@Model.Prs.DateCreation.ToString("dd/MM/yyyy HH:mm"))</span>
            </div>
        }
    </div>

    @if (!canEdit)
    {
        <div class="permissions-banner">
            <div class="d-flex align-items-center">
                <i class="fas fa-lock me-2 fs-5"></i>
                <span><strong>Accès en lecture seule :</strong> Vous ne disposez pas des droits nécessaires pour modifier cette PRS.</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Flash))
    {
        <div class="alert alert-success alert-modern">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle me-2 fs-5"></i>
                <span>@Model.Flash</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-modern">
            <div><i class="fas fa-exclamation-triangle me-2 fs-5"></i><strong>Erreurs détectées :</strong></div>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="mt-1">• @error.ErrorMessage</div>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="form-container">
        <form method="post" class="row g-3" id="create-form" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Prs.Id" />
            <input type="hidden" asp-for="Prs.DateCreation" />
            <input type="hidden" asp-for="Prs.CreatedByLogin" />
            @* Toujours poster les dates même en lecture seule *@
            @if (!canEdit)
            {
                <input type="hidden" asp-for="Prs.DateDebut" value="@Model.Prs.DateDebut.ToString("yyyy-MM-ddTHH:mm")" />
                <input type="hidden" asp-for="Prs.DateFin" value="@Model.Prs.DateFin.ToString("yyyy-MM-ddTHH:mm")" />
            }

            <div class="col-md-6">
                <label asp-for="Prs.Titre" class="form-label"><i class="fas fa-tag"></i> Titre de la PRS</label>
                <input asp-for="Prs.Titre" class="form-control @(!canEdit ? "readonly-field" : "")" readonly="@(!canEdit)" />
                <span asp-validation-for="Prs.Titre" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.Equipement" class="form-label"><i class="fas fa-cogs"></i> Type d'équipement</label>
                <select asp-for="Prs.Equipement" class="form-select @(!canEdit ? "readonly-field" : "")" disabled="@(!canEdit)">
                    <option value="">-- Sélectionner un type --</option>
                    <option value="CMS">🏭 CMS</option>
                    <option value="Finition">✨ Finition</option>
                </select>
                @if (!canEdit)
                {
                    <input type="hidden" name="Prs.Equipement" value="@Model.Prs.Equipement" />
                }
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.ReferenceProduit" class="form-label"><i class="fas fa-barcode"></i> Référence produit</label>
                <input asp-for="Prs.ReferenceProduit" class="form-control @(!canEdit ? "readonly-field" : "")" readonly="@(!canEdit)" />
            </div>

            <div class="col-md-3">
                <label asp-for="Prs.Quantite" class="form-label"><i class="fas fa-hashtag"></i> Quantité</label>
                <input asp-for="Prs.Quantite" type="number" min="1" class="form-control @(!canEdit ? "readonly-field" : "")" readonly="@(!canEdit)" />
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.BesoinOperateur" class="form-label"><i class="fas fa-user-hard-hat"></i> Besoin opérateur</label>
                <select asp-for="Prs.BesoinOperateur" class="form-select @(!canEdit ? "readonly-field" : "")" disabled="@(!canEdit)">
                    <option value="">-- Sélectionner --</option>
                    <option value="Besoin opérateur">👨‍🔧 Besoin opérateur</option>
                    <option value="Aucun">❌ Aucun</option>
                </select>
                @if (!canEdit)
                {
                    <input type="hidden" name="Prs.BesoinOperateur" value="@Model.Prs.BesoinOperateur" />
                }
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.PresenceClient" class="form-label"><i class="fas fa-user-tie"></i> Présence client</label>
                <select asp-for="Prs.PresenceClient" class="form-select @(!canEdit ? "readonly-field" : "")" disabled="@(!canEdit)">
                    <option value="">-- Sélectionner --</option>
                    <option value="Client présent">✅ Client présent</option>
                    <option value="Client absent">❌ Client absent</option>
                    <option value="Non spécifié">❓ Non spécifié</option>
                </select>
                @if (!canEdit)
                {
                    <input type="hidden" name="Prs.PresenceClient" value="@Model.Prs.PresenceClient" />
                }
            </div>

            <!-- ROB.I.A -->
            <div class="col-md-12">
                <div class="card robia-card border-info">
                    <div class="card-header bg-gradient-info text-white d-flex align-items-center">
                        <i class="fas fa-robot robot-icon me-2 fs-5"></i>
                        <div>
                            <h6 class="mb-0">🤖 ROB.I.A - Planification Intelligente</h6>
                            <small>Rapid Optimal Booking Intelligent Assistant</small>
                        </div>
                        <div class="ms-auto"><span class="badge bg-success fs-6"><i class="fas fa-circle me-1"></i>Prêt</span></div>
                    </div>
                    <div class="card-body bg-light">
                        <div class="row g-3">
                            @if (canEdit && isAdminOrValidateur)
                            {
                                <div class="col-md-3">
                                    <label asp-for="Prs.DateDebut" class="form-label fw-bold"><i class="fas fa-calendar-alt text-primary"></i> Début</label>
                                    <input asp-for="Prs.DateDebut" type="datetime-local" class="form-control" value="@Model.Prs.DateDebut.ToString("yyyy-MM-ddTHH:mm")" />
                                    <span asp-validation-for="Prs.DateDebut" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Prs.DateFin" class="form-label fw-bold"><i class="fas fa-calendar-check text-success"></i> Fin</label>
                                    <input asp-for="Prs.DateFin" type="datetime-local" class="form-control" value="@Model.Prs.DateFin.ToString("yyyy-MM-ddTHH:mm")" />
                                    <span asp-validation-for="Prs.DateFin" class="text-danger"></span>
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <select id="duration-select" class="form-select">
                                        <option value="1">⏱️ 1h</option>
                                        <option value="2">⏱️ 2h</option>
                                        <option value="4">🕐 4h</option>
                                        <option value="8" selected>🕓 8h</option>
                                        <option value="16">📅 16h</option>
                                        <option value="24">📅 24h</option>
                                        <option value="40">📅 40h</option>
                                    </select>
                                </div>
                            }
                            else if (canEdit && !isAdminOrValidateur)
                            {
                                <input type="hidden" name="weekMode" id="weekMode" value="true" />
                                <input type="hidden" name="selectedWeek" id="selectedWeek" value="" />
                                <div class="col-md-6">
                                    <label class="form-label fw-bold"><i class="fas fa-calendar-week text-primary"></i> Semaine</label>
                                    <div class="week-selector">
                                        <div class="week-navigation">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" id="prevWeek"><i class="fas fa-chevron-left"></i> Précédente</button>
                                            <div class="week-info" id="weekInfo">Semaine en cours</div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" id="nextWeek">Suivante <i class="fas fa-chevron-right"></i></button>
                                        </div>
                                        <div class="week-view"><div class="week-days" id="weekDays"></div></div>
                                        <div class="week-selected" id="weekSelected">
                                            <p class="mb-0">Vous avez sélectionné:</p>
                                            <p class="week-highlight mb-0" id="weekHighlight"></p>
                                            <small class="text-muted">Lun 00:00 -> Lun suivant 00:00</small>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" asp-for="Prs.DateDebut" id="hiddenDateDebut" />
                                <input type="hidden" asp-for="Prs.DateFin" id="hiddenDateFin" />
                            }
                            <div class="col-md-3 @(canEdit ? "d-flex align-items-end" : "d-none")">
                                <button type="button" class="btn btn-robia w-100" id="suggest-slot-btn" @(canEdit ? null : "disabled")>🤖 ROB.I.A Analyser</button>
                            </div>
                        </div>
                        <div class="mt-3 p-3 bg-info bg-opacity-10 rounded">
                            <small class="text-muted"><i class="fas fa-info-circle text-info me-1"></i> ROB.I.A analyse les créneaux disponibles.</small>
                        </div>
                    </div>
                </div>
            </div>

            <div id="robia-suggestions" class="mt-4" style="display: none;">
                <div class="card border-success shadow-lg">
                    <div class="card-header bg-gradient-success text-dark d-flex align-items-center">
                        <i class="fas fa-robot robot-icon me-2 fs-4"></i>
                        <div><h5 class="mb-0">🎯 ROB.I.A - Suggestions</h5><small>v1.0</small></div>
                        <div class="ms-auto"><span class="badge bg-light text-dark">IA Active</span></div>
                    </div>
                    <div class="card-body">
                        <div id="suggestions-content"></div>
                        <div class="mt-4 text-center">
                            <button type="button" class="btn btn-success btn-lg me-3" id="apply-suggestion" @(canEdit ? null : "disabled")><i class="fas fa-check-circle me-2"></i>Appliquer</button>
                            <button type="button" class="btn btn-warning me-3" id="show-alternatives" @(canEdit ? null : "disabled")><i class="fas fa-sync-alt me-2"></i>Alternative</button>
                            <button type="button" class="btn btn-secondary" id="close-suggestions"><i class="fas fa-times me-2"></i>Fermer</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.LigneId" class="form-label"><i class="fas fa-industry"></i> Ligne</label>
                <select asp-for="Prs.LigneId" asp-items="Model.LigneList" class="form-select @(!canEdit ? "readonly-field" : "")" id="ligne-select" disabled="@(!canEdit)" required>
                    <option value="">-- Choisir une ligne --</option>
                </select>
                @if (!canEdit)
                {
                    <input type="hidden" name="Prs.LigneId" value="@Model.Prs.LigneId" />
                }
                <span asp-validation-for="Prs.LigneId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Prs.FamilleId" class="form-label"><i class="fas fa-layer-group"></i> Famille de produit</label>
                <select asp-for="Prs.FamilleId" class="form-select @(!canEdit ? "readonly-field" : "")" disabled="@(!canEdit)">
                    <option value="">-- Aucune famille --</option>
                    @foreach (var fam in Model.Familles)
                    {
                        <option value="@fam.Id" selected="@(Model.Prs.FamilleId == fam.Id)">@fam.Libelle</option>
                    }
                </select>
                @if (!canEdit)
                {
                    <input type="hidden" name="Prs.FamilleId" value="@(Model.Prs.FamilleId?.ToString() ?? "")" />
                }
            </div>

            <!-- Liens PRS -->
            <div class="col-md-12">
                <div class="card border-warning">
                    <div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="fas fa-folder-open me-2"></i>Liens vers dossiers PRS</h5></div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-5">
                                <label for="folderPathDisplay" class="form-label fw-bold">Chemin complet du dossier</label>
                                <input type="text" class="form-control @(canEdit ? "" : "readonly-field")" id="folderPathDisplay" placeholder="Ex : S:\Logistique\Appros" @(canEdit ? null : "readonly") style="font-family: Consolas, monospace;">
                                <small class="text-muted">Copiez-collez le chemin complet du dossier</small>
                            </div>
                            <div class="col-md-5">
                                <label for="folderDescription" class="form-label">Description (optionnelle)</label>
                                <input type="text" class="form-control @(canEdit ? "" : "readonly-field")" id="folderDescription" placeholder="Ex: Dossier technique, Documentation client..." @(canEdit ? null : "readonly")>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button class="btn btn-warning w-100" type="button" id="btnAddFolder" @(canEdit ? null : "disabled")><i class="fas fa-plus-circle"></i> Ajouter</button>
                            </div>
                        </div>
                        <div class="alert alert-info mt-3 mb-3">
                            <i class="fas fa-info-circle me-2"></i> Copiez-collez le chemin complet (ex : <code>S:\Logistique\Appros</code>)
                        </div>
                        <input type="hidden" name="PrsFolderLinks" id="prsFolderLinks" value="" />
                        <ul class="folder-list mt-3" id="folderList">
                            @foreach (var link in Model.LiensDossiers)
                            {
                                <li class="folder-item" data-path="@link.Chemin">
                                    <i class="fas fa-folder folder-icon"></i>
                                    <span class="folder-path">@link.Chemin</span>
                                    @if (!string.IsNullOrWhiteSpace(link.Description))
                                    {
                                        <span class="folder-description">@link.Description</span>
                                    }
                                    <i class="fas fa-times remove-folder ms-auto" title="Retirer" role="button" @(canEdit ? null : "style=\"pointer-events:none;opacity:0.3;\"")></i>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            @if (isAdminOrValidateur && canEdit)
            {
                <div class="col-md-6">
                    <label asp-for="Prs.CouleurPRS" class="form-label"><i class="fas fa-palette"></i> Couleur PRS <span class="badge bg-warning text-dark ms-2">Admin/Validateur</span></label>
                    <div class="input-group">
                        <input asp-for="Prs.CouleurPRS" type="color" class="form-control form-control-color" style="width: 60px; height: 38px;" value="@(string.IsNullOrEmpty(Model.Prs.CouleurPRS) ? "#007bff" : Model.Prs.CouleurPRS)" />
                        <input asp-for="Prs.CouleurPRS" type="text" class="form-control" placeholder="#FF5733" pattern="^#[0-9A-Fa-f]{6}$" value="@Model.Prs.CouleurPRS" />
                        <button type="button" class="btn btn-outline-secondary" id="clearColor"><i class="fas fa-times"></i></button>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.Prs.CouleurPRS))
            {
                <div class="col-md-6">
                    <label class="form-label"><i class="fas fa-palette"></i> Couleur PRS</label>
                    <div class="input-group">
                        <input type="color" class="form-control form-control-color readonly-field" style="width: 60px; height: 38px;" readonly value="@Model.Prs.CouleurPRS" />
                        <input type="text" class="form-control readonly-field" readonly value="@Model.Prs.CouleurPRS" />
                    </div>
                    <input type="hidden" name="Prs.CouleurPRS" value="@Model.Prs.CouleurPRS" />
                </div>
            }

            <div class="col-md-12">
                <label asp-for="Prs.InfoDiverses" class="form-label"><i class="fas fa-comment-alt"></i> Informations complémentaires</label>
                <textarea asp-for="Prs.InfoDiverses" class="form-control @(!canEdit ? "readonly-field" : "")" readonly="@(!canEdit)" rows="3"></textarea>
            </div>

            <!-- Pièces jointes -->
            <div class="col-md-12">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-file-upload me-2"></i>Pièces jointes</h5>
                    </div>
                    <div class="card-body">
                        <div class="file-upload-container @(canEdit ? "" : "disabled-field")" id="dropZone">
                            <i class="fas fa-cloud-upload-alt file-upload-icon"></i>
                            <p class="file-upload-text">
                                Glissez-déposez vos fichiers ici ou <strong>cliquez pour sélectionner</strong>
                            </p>
                            <input type="file" multiple name="UploadedFiles" class="file-upload-input" id="fileUpload" @(canEdit ? null : "disabled") />
                            <div class="progress-container" id="uploadProgress">
                                <div class="progress-bar" id="progressBar"></div>
                            </div>
                            <p class="upload-limits">
                                <i class="fas fa-info-circle"></i> Taille max: 100 Mo par fichier | Tous formats acceptés
                            </p>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="mt-2">Fichiers existants</h6>
                                <ul class="file-list" id="existingFileList">
                                    @foreach (var f in Model.PrsFichiers)
                                    {
                                        <li class="file-item" data-file-id="@f.Id" data-file-path="@f.CheminFichier">
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-file file-icon"></i>
                                                <span class="file-name">@f.NomOriginal</span>
                                                <span class="file-size">(@(Math.Round((decimal)f.Taille / 1024m / 1024m, 2)) Mo)</span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <a class="btn btn-sm btn-outline-primary me-2"
                                                   href="@Url.Page("Edit", "DownloadFile", new { id = Model.Prs.Id, fileId = f.Id })"
                                                   title="Télécharger">
                                                    <i class="fas fa-download"></i>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger remove-file"
                                                        data-file-id="@f.Id"
                                                        title="Supprimer"
                                                @(canEdit ? null : "disabled")>
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>

                            <div class="col-md-6">
                                <h6 class="mt-2">Nouveaux fichiers (à uploader)</h6>
                                <ul class="file-list" id="newFileList"></ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Affectations PRS -->
            <div class="form-section">
                <div class="section-header">
                    <h4><i class="fas fa-users text-info"></i> Affectation des personnes</h4>
                    <p class="text-muted mb-0">Affectez des utilisateurs ou des groupes</p>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label class="form-label"><i class="fas fa-user me-1"></i> Ajouter un utilisateur</label>
                            <div class="input-group">
                                <select id="userSelect" class="form-select" @(canEdit ? null : "disabled")>
                                    <option value="">Sélectionner un utilisateur...</option>
                                    @foreach (var user in Model.Utilisateurs.OrderBy(u => u.Nom).ThenBy(u => u.Prenom))
                                    {
                                        <option value="@user.Id" data-type="Utilisateur" data-name="@user.Prenom @user.Nom" data-service="@user.Service">
                                            @user.Nom @user.Prenom (@user.Service)
                                        </option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" id="addUserBtn" @(canEdit ? null : "disabled")><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label class="form-label"><i class="fas fa-users me-1"></i> Ajouter un groupe</label>
                            <div class="input-group">
                                <select id="groupSelect" class="form-select" @(canEdit ? null : "disabled")>
                                    <option value="">Sélectionner un groupe...</option>
                                    @foreach (var g in Model.GroupesUtilisateurs.OrderBy(g => g.NomGroupe))
                                    {
                                        <option value="@g.Id" data-type="Groupe" data-name="@g.NomGroupe" data-count="@g.Membres.Count">
                                            @g.NomGroupe (@g.Membres.Count membres)
                                        </option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-success" id="addGroupBtn" @(canEdit ? null : "disabled")><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <h6><i class="fas fa-list me-1"></i>Personnes affectées</h6>
                    <ul id="affectationsList" class="list-group">
                        @if (Model.AffectationsExistantesDisplay != null && Model.AffectationsExistantesDisplay.Any())
                        {
                            @foreach (var a in Model.AffectationsExistantesDisplay)
                            {
                                <li class="list-group-item d-flex align-items-center" data-existing="true" data-affectation-id="@a.Id" data-type="@a.Type">
                                    <i class="fas @(a.Type == "Utilisateur" ? "fa-user" : "fa-users") me-2"></i>
                                    <span class="me-auto">
                                        @a.Name @if (!string.IsNullOrEmpty(a.Info))
                                        {
                                            <span class="text-muted">(@a.Info)</span>
                                        }
                                    </span>
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-aff" title="Retirer cette affectation" @(canEdit ? null : "disabled")>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted"><i class="fas fa-info-circle me-2"></i> Aucune affectation pour le moment.</li>
                        }
                    </ul>
                </div>

                <input type="hidden" name="AffectationsData" id="affectationsData" value="[]" />
                <input type="hidden" name="AffectationsToDelete" id="affectationsToDelete" value="[]" />
            </div>

            <!-- Checklist PRS -->
            <div class="col-12">
                <div class="card checklist-section border-primary shadow-lg mb-4">
                    <div class="card-header bg-primary text-white d-flex align-items-center">
                        <i class="fas fa-tasks me-2 fs-4"></i>
                        <div>
                            <h5 class="mb-0">📋 Checklist PRS</h5>
                            <small>Associez une checklist à cette PRS</small>
                        </div>
                        @if (hasChecklist)
                        {
                            <span class="badge bg-success ms-auto">Checklist existante</span>
                        }
                    </div>
                    <div class="card-body">
                        <div class="checklist-type-selector mb-4 row">
                            <div class="col-md-4">
                                <label class="form-label fw-bold"><i class="fas fa-clipboard-list me-1 text-primary"></i>Type de checklist</label>
                                <select id="checklistTypeSelector" class="form-select" @(canEdit ? null : "disabled")>
                                    @if (!hasChecklist)
                                    {
                                        <option value="" selected>-- Aucune checklist --</option>
                                    }
                                    else
                                    {
                                        <option value="">-- Aucune checklist --</option>
                                    }
                                    <option value="modele">🎯 Modèle prédéfini</option>
                                    <option value="copy">📋 Copier depuis PRS existante</option>
                                    <option value="custom">✏️ Personnalisée</option>
                                </select>
                            </div>
                            <div class="col-md-4" id="modeleSelector" style="display:none;">
                                <label class="form-label fw-bold"><i class="fas fa-list me-1 text-success"></i>Modèle disponible</label>
                                <select id="checklistModele" class="form-select" @(canEdit ? null : "disabled")>
                                    <option value="">-- Sélectionner un modèle --</option>
                                    @foreach (var modele in Model.ChecklistModeles)
                                    {
                                        <option value="@modele.Id">@modele.Nom (@modele.FamilleAffichage)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4" id="prsSelector" style="display:none;">
                                <label class="form-label fw-bold"><i class="fas fa-copy me-1 text-info"></i>PRS source</label>
                                <select id="prsSourceSelect" class="form-select" @(canEdit ? null : "disabled")>
                                    <option value="">-- Chargement des PRS... --</option>
                                </select>
                                <small class="text-muted mt-1 d-block">Sélectionnez une PRS existante avec une checklist à copier</small>
                            </div>
                        </div>

                        <div id="prsSearchResults" class="prs-search-results" style="display:none;"></div>

                        <div id="checklistEditor" class="checklist-editor" style="display:none;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0"><i class="fas fa-edit me-1"></i>Éléments de la checklist (<span id="checklistItemCount" class="badge-checklist">0</span> éléments)</h6>
                                <button type="button" class="btn btn-sm btn-checklist" id="addChecklistItem" @(canEdit ? null : "disabled")>
                                    <i class="fas fa-plus-circle me-1"></i>Ajouter un élément
                                </button>
                            </div>
                            <div id="checklistItems" class="checklist-items-container"></div>
                        </div>

                        @* Au chargement: forcer "copy" depuis la PRS courante pour déclencher l'affichage *@
                        <input type="hidden" id="checklistData" name="ChecklistData" value='@Html.Raw(hasChecklist ? $"{{\"type\":\"copy\",\"sourceId\":{Model.Prs.Id},\"elements\":[]}}" : (Model.ChecklistInitialJson ?? "null"))' />
                        <input type="hidden" id="checklistAffectationsData" name="ChecklistAffectationsData" value='{"users":[],"groups":[]}' />
                        <input type="hidden" id="checklistDataOriginal" value='@Html.Raw(Model.ChecklistInitialJson ?? "null")' />
                    </div>
                </div>
            </div>

            <div class="col-12 text-center">

                <!-- Appelle le handler OnPostCreateNewAsync ci-dessous -->
                <button type="submit" asp-page-handler="CreateNew" class="btn btn-success btn-lg px-5 me-3">
                    <i class="fas fa-save me-2"></i>Enregistrer
                </button>

                <a href="javascript:history.back()" class="btn btn-secondary btn-lg px-5">
                    <i class="fas fa-times me-2"></i>@(canEdit ? "Annuler" : "Retour")
                </a>

            </div>

        </form>
    </div>
</div>

<div class="calendar-section-title">
    <h4 class="calendar-standalone-title"><i class="fas fa-calendar-alt"></i> Visualisation du planning (créneaux existants)</h4>
</div>
@Html.Partial("_CalendarBlock")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const isAdminOrValidateur = @Json.Serialize(isAdminOrValidateur);
        const canEdit = @Json.Serialize(canEdit);
        const prsId = @Model.Prs.Id;
        const hasChecklist = @Json.Serialize(Model.HasExistingChecklist);
        console.log('[EDIT] Init page Edit PRS', { prsId, canEdit, isAdminOrValidateur });

        function updateChecklistTypeVisibility() {
            const typeSel = document.getElementById('checklistTypeSelector');
            const modeleRow = document.getElementById('modeleSelector');
            const prsRow = document.getElementById('prsSelector');
            const editor = document.getElementById('checklistEditor');
            const type = typeSel?.value || '';

            if (modeleRow) modeleRow.style.display = (type === 'modele') ? '' : 'none';
            if (prsRow) prsRow.style.display = (type === 'copy') ? '' : 'none';
            if (editor) editor.style.display = (type === '') ? 'none' : '';
        }

        // Pré-sélection et forçage d'affichage: Type=copy, PRS source = PRS courante
        document.addEventListener('DOMContentLoaded', function () {
            const typeSel = document.getElementById('checklistTypeSelector');
            const prsSel = document.getElementById('prsSourceSelect');
            const hidden = document.getElementById('checklistData');

            // 1) Forcer type=copy visuellement et côté hidden
            if (typeSel) typeSel.value = 'copy';
            if (hidden && hasChecklist) {
                hidden.value = JSON.stringify({ type: 'copy', sourceId: prsId, elements: [] });
            }
            updateChecklistTypeVisibility();

            // 2) Rendre visible "PRS source" immédiatement
            const prsRow = document.getElementById('prsSelector');
            if (prsRow) prsRow.style.display = '';

            // 3) Sélectionner PRS courante dans le select (une fois qu'il est peuplé par le manager)
            function trySetPrsSource() {
                if (!prsSel) return true;
                const wanted = String(prsId);
                let found = false;
                for (const o of prsSel.options) {
                    if (o.value === wanted) { found = true; break; }
                }
                if (found) {
                    prsSel.value = wanted;
                    prsSel.dispatchEvent(new Event('change', { bubbles: true }));
                    console.log('[EDIT] Checklist: PRS source pré-sélectionnée =', wanted);
                    return true;
                }
                return false;
            }

            // Premier essai direct
            if (!trySetPrsSource()) {
                // Poll court pour attendre le remplissage asynchrone du manager
                let attempts = 0, max = 100; // ~5s avec 50ms
                const timer = setInterval(() => {
                    attempts++;
                    if (trySetPrsSource() || attempts >= max) {
                        if (!trySetPrsSource() && prsSel) {
                            // Fallback: injecte l'option si elle n'est pas encore présente
                            const opt = new Option('PRS #' + prsId + ' (courante)', String(prsId), true, true);
                            prsSel.appendChild(opt);
                            prsSel.dispatchEvent(new Event('change', { bubbles: true }));
                            console.warn('[EDIT] Checklist: option PRS courante injectée (fallback).');
                        }
                        clearInterval(timer);
                    }
                }, 50);
            }

            // 4) Le manager écrase parfois le hidden au démarrage: re-force après 300ms
            setTimeout(() => {
                try {
                    const parsed = JSON.parse(hidden?.value || '{}');
                    if (!parsed || !parsed.type || parsed.type === '' || parsed.sourceId == null) {
                        if (hidden) hidden.value = JSON.stringify({ type: 'copy', sourceId: prsId, elements: [] });
                        if (typeSel) typeSel.value = 'copy';
                        updateChecklistTypeVisibility();
                        // Déclenche une mise à jour globale pour le manager
                        typeSel?.dispatchEvent(new Event('change', { bubbles: true }));
                        prsSel?.dispatchEvent(new Event('change', { bubbles: true }));
                        console.warn('[EDIT] Checklist: hidden restauré (post-init manager).');
                    }
                } catch (e) {
                    console.error('[EDIT] Post-init checklist fix error:', e);
                }
            }, 300);

            console.log('[EDIT] ChecklistData (init hidden):', hidden ? hidden.value : null);

            // Change handler pour afficher/cacher les sections quand l'utilisateur modifie le type
            typeSel?.addEventListener('change', updateChecklistTypeVisibility);
        });
    </script>

    <script src="~/js/file-upload.js" asp-append-version="true"></script>
    <script src="~/js/checklist-manager.js" asp-append-version="true"></script>

    <script>
        // Semaine (utilisateurs non-admin)
        const hiddenDateDebutInput = document.querySelector("#hiddenDateDebut");
        const hiddenDateFinInput = document.querySelector("#hiddenDateFin");
        const weekInfoElem = document.querySelector("#weekInfo");
        const weekDaysElem = document.querySelector("#weekDays");
        const weekHighlightElem = document.querySelector("#weekHighlight");
        const selectedWeekInput = document.querySelector("#selectedWeek");
        let currentWeekStart;

        if (canEdit && !isAdminOrValidateur && weekInfoElem && weekDaysElem) {
            currentWeekStart = getMonday(new Date(@Json.Serialize(Model.Prs.DateDebut)));
            initWeekSelector();
            updateHiddenDateFields();
        }
        function getMonday(date) { const d = new Date(date); const day = d.getDay(); const diff = d.getDate() - day + (day === 0 ? -6 : 1); return new Date(d.setDate(diff)); }
        function formatDateFr(date) { const options = { day: 'numeric', month: 'long', year: 'numeric' }; return date.toLocaleDateString('fr-FR', options); }
        function getDayName(date) { return date.toLocaleDateString('fr-FR', { weekday: 'short' }); }
        function initWeekSelector() {
            updateWeekDisplay();
            document.getElementById('prevWeek')?.addEventListener('click', () => { currentWeekStart.setDate(currentWeekStart.getDate() - 7); updateWeekDisplay(); });
            document.getElementById('nextWeek')?.addEventListener('click', () => { currentWeekStart.setDate(currentWeekStart.getDate() + 7); updateWeekDisplay(); });
        }
        function updateWeekDisplay() {
            if (!weekInfoElem || !weekDaysElem || !weekHighlightElem) return;
            const weekEnd = new Date(currentWeekStart); weekEnd.setDate(weekEnd.getDate() + 6);
            weekInfoElem.textContent = `Semaine ${getWeekNumber(currentWeekStart)} - ${currentWeekStart.getFullYear()}`;
            weekHighlightElem.textContent = `Semaine du ${formatDateFr(currentWeekStart)} au ${formatDateFr(weekEnd)}`;
            if (selectedWeekInput) selectedWeekInput.value = currentWeekStart.toISOString();
            weekDaysElem.innerHTML = '';
            for (let i = 0; i < 7; i++) {
                const day = new Date(currentWeekStart); day.setDate(day.getDate() + i);
                const dayElement = document.createElement('div');
                dayElement.className = 'week-day';
                const nameDiv = document.createElement('div'); nameDiv.className = 'day-name'; nameDiv.textContent = getDayName(day);
                const numDiv = document.createElement('div'); numDiv.className = 'day-number'; numDiv.textContent = String(day.getDate());
                dayElement.appendChild(nameDiv); dayElement.appendChild(numDiv);
                weekDaysElem.appendChild(dayElement);
            }
            updateHiddenDateFields();
        }
        function getWeekNumber(date) { const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate())); const dayNum = d.getUTCDay() || 7; d.setUTCDate(d.getUTCDate() + 4 - dayNum); const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1)); return Math.ceil((((d - yearStart) / 86400000) + 1) / 7); }
        function updateHiddenDateFields() {
            if (!currentWeekStart || !hiddenDateDebutInput || !hiddenDateFinInput) return;
            const mondayStart = new Date(currentWeekStart); mondayStart.setHours(0, 0, 0, 0);
            const nextMonday = new Date(mondayStart); nextMonday.setDate(nextMonday.getDate() + 7);
            hiddenDateDebutInput.value = mondayStart.toISOString().slice(0, 16);
            hiddenDateFinInput.value = nextMonday.toISOString().slice(0, 16);
        }

        // Couleur PRS admin
        document.getElementById('clearColor')?.addEventListener('click', function () {
            const colorPicker = document.querySelector('input[type="color"][name="Prs.CouleurPRS"]');
            const colorText = document.querySelector('input[type="text"][name="Prs.CouleurPRS"]');
            if (colorPicker && colorText) { colorPicker.value = '#007bff'; colorText.value = ''; }
            console.log('[EDIT] Couleur PRS remise à défaut');
        });

        // Validation
        document.querySelector("#create-form")?.addEventListener("submit", function (e) {
            const dateDebutInput = document.querySelector("#Prs_DateDebut");
            const dateFinInput = document.querySelector("#Prs_DateFin");
            const ligneSelect = document.querySelector("#ligne-select");
            if (isAdminOrValidateur && dateDebutInput && dateFinInput) {
                const dateDebut = new Date(dateDebutInput.value);
                const dateFin = new Date(dateFinInput.value);
                if (dateFin <= dateDebut) { e.preventDefault(); alert('La date de début doit être antérieure à la date de fin.'); return false; }
            }
            if (ligneSelect && !ligneSelect.value) { e.preventDefault(); alert('Veuillez sélectionner une ligne.'); ligneSelect.focus(); return false; }
            console.log('[EDIT] Soumission du formulaire');
        });

        // Suppression fichier (delegation)
        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('.remove-file');
            if (!btn) return;
            if (!canEdit) return;
            const id = btn.getAttribute('data-file-id');
            if (!id) return;
            if (!confirm('Supprimer ce fichier ?')) return;

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const url = `@Url.Page("Edit", "DeleteFile", new { id = Model.Prs.Id })&fileId=${encodeURIComponent(id)}`;
                const resp = await fetch(url, { method: 'POST', headers: { 'RequestVerificationToken': token } });
                if (resp.ok) {
                    document.querySelector('.file-item[data-file-id="' + id + '"]')?.remove();
                } else {
                    alert('Suppression impossible.');
                }
            } catch (err) {
                console.error('[EDIT] Erreur suppression fichier', err);
                alert('Erreur lors de la suppression.');
            }
        });

        // Liens dossiers -> hidden JSON
        function updateFolderLinksHidden() {
            const items = Array.from(document.querySelectorAll('#folderList .folder-item')).map(li => {
                return { Chemin: li.getAttribute('data-path'), Description: (li.querySelector('.folder-description')?.textContent || '').trim() };
            });
            const json = JSON.stringify(items);
            document.getElementById('prsFolderLinks').value = json;
            console.log('[EDIT] Liens PRS => hidden', json);
        }
        document.addEventListener('DOMContentLoaded', updateFolderLinksHidden);

        // Ajout d'un lien (DOM safe)
        document.getElementById('btnAddFolder')?.addEventListener('click', () => {
            if (!canEdit) return;
            const path = document.getElementById('folderPathDisplay').value.trim();
            const desc = document.getElementById('folderDescription').value.trim();
            if (!path) { console.warn('[EDIT] Lien PRS: chemin vide'); return; }

            const li = document.createElement('li'); li.className = 'folder-item'; li.setAttribute('data-path', path);

            const icon = document.createElement('i'); icon.className = 'fas fa-folder folder-icon';
            const spanPath = document.createElement('span'); spanPath.className = 'folder-path'; spanPath.textContent = path;
            li.appendChild(icon); li.appendChild(spanPath);

            if (desc) { const spanDesc = document.createElement('span'); spanDesc.className = 'folder-description'; spanDesc.textContent = desc; li.appendChild(spanDesc); }

            const remove = document.createElement('i'); remove.className = 'fas fa-times remove-folder ms-auto'; remove.title = 'Retirer'; remove.setAttribute('role','button');
            li.appendChild(remove);

            document.getElementById('folderList').appendChild(li);
            document.getElementById('folderPathDisplay').value = ''; document.getElementById('folderDescription').value = '';
            updateFolderLinksHidden();
            console.log('[EDIT] Lien dossier ajouté', { path, desc });
        });

        // Suppression d’un lien (event delegation)
        document.addEventListener('click', (e) => {
            const btn = e.target.closest('.remove-folder');
            if (!btn) return;
            if (!canEdit) return;
            const li = btn.closest('.folder-item');
            const path = li?.getAttribute('data-path');
            li?.remove();
            updateFolderLinksHidden();
            console.log('[EDIT] Lien dossier supprimé', { path });
        });

        // Affectations PRS (ajout/suppression + logs via delegation) — version robuste
        document.addEventListener('DOMContentLoaded', function () {
            function getList() {
                return document.getElementById('affectationsList');
            }

            const dataField = document.getElementById('affectationsData');
            const delField = document.getElementById('affectationsToDelete');
            let pending = []; // {id,type,name,info}

            function syncPending() {
                if (!dataField) return;
                dataField.value = JSON.stringify(pending.map(p => ({ id: p.id, type: p.type, name: p.name, info: p.info })));
                console.log('[EDIT] Affectations (pending sync) =>', dataField.value);
            }

            function addListItem(item) {
                const list = getList();
                if (!list) {
                    console.error('[EDIT] UL #affectationsList introuvable au moment d’ajouter un item.', item);
                    alert('Zone "Personnes affectées" introuvable. Rechargez la page ou contactez un admin.');
                    return;
                }

                const li = document.createElement('li');
                li.className = 'list-group-item d-flex align-items-center';
                li.dataset.type = item.type;

                const icon = document.createElement('i');
                icon.className = 'fas ' + (item.type === 'Utilisateur' ? 'fa-user' : 'fa-users') + ' me-2';

                const span = document.createElement('span');
                span.className = 'me-auto';
                span.textContent = item.name;
                if (item.info) {
                    const infoSpan = document.createElement('span');
                    infoSpan.className = 'text-muted';
                    infoSpan.textContent = ' (' + item.info + ')';
                    span.appendChild(infoSpan);
                }

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'btn btn-sm btn-outline-danger btn-remove-aff';
                btn.title = 'Retirer';
                const i = document.createElement('i');
                i.className = 'fas fa-trash';
                btn.appendChild(i);

                li.appendChild(icon);
                li.appendChild(span);
                li.appendChild(btn);
                list.appendChild(li);
            }

            console.log('[EDIT] affectationsList présent ?', !!getList());

            document.getElementById('addUserBtn')?.addEventListener('click', () => {
                if (!getList()) { console.warn('[EDIT] Pas de #affectationsList au clic addUserBtn'); return; }
                const sel = document.getElementById('userSelect');
                const val = parseInt(sel?.value || '0', 10);
                if (!val) { console.warn('[EDIT] Aucun utilisateur sélectionné'); return; }
                const opt = sel.selectedOptions[0];
                const name = opt?.getAttribute('data-name') || opt?.textContent || '';
                const info = opt?.getAttribute('data-service') || '';
                const item = { id: val, type: 'Utilisateur', name, info };
                if (!pending.some(x => x.id === item.id && x.type === item.type)) pending.push(item);
                addListItem(item);
                syncPending();
                sel.value = '';
            });

            document.getElementById('addGroupBtn')?.addEventListener('click', () => {
                if (!getList()) { console.warn('[EDIT] Pas de #affectationsList au clic addGroupBtn'); return; }
                const sel = document.getElementById('groupSelect');
                const val = parseInt(sel?.value || '0', 10);
                if (!val) { console.warn('[EDIT] Aucun groupe sélectionné'); return; }
                const opt = sel.selectedOptions[0];
                const name = opt?.getAttribute('data-name') || opt?.textContent || '';
                const count = opt?.getAttribute('data-count') || '';
                const info = count ? (count + ' membres') : '';
                const item = { id: val, type: 'Groupe', name, info };
                if (!pending.some(x => x.id === item.id && x.type === item.type)) pending.push(item);
                addListItem(item);
                syncPending();
                sel.value = '';
            });

            document.addEventListener('click', (e) => {
                const btn = e.target.closest('.btn-remove-aff');
                if (!btn) return;
                const li = btn.closest('li');
                if (!li) return;

                if (li.dataset.existing === 'true') {
                    const affId = li.dataset.affectationId;
                    if (affId && delField) {
                        const arr = delField.value ? JSON.parse(delField.value) : [];
                        const num = parseInt(affId, 10);
                        if (!arr.includes(num)) arr.push(num);
                        delField.value = JSON.stringify(arr);
                        console.log('[EDIT] Affectation EXISTANTE marquée pour suppression', arr);
                    }
                } else {
                    const nameText = (li.querySelector('span.me-auto')?.childNodes[0]?.nodeValue || '').trim();
                    const type = li.dataset.type || 'Utilisateur';
                    pending = pending.filter(x => !(x.name === nameText && x.type === type));
                    syncPending();
                    console.log('[EDIT] Affectation (pending) retirée', { nameText, type });
                }
                li.remove();
            });
        });

        // ROBIA inline — mêmes suggestions qu'Edit: liste d'alternatives, sélection/rotation, exclusion du créneau courant
        (function () {
            const btn = document.getElementById('suggest-slot-btn');
            const container = document.getElementById('robia-suggestions');
            const content = document.getElementById('suggestions-content');
            const applyBtn = document.getElementById('apply-suggestion');
            const altBtn = document.getElementById('show-alternatives');
            const closeBtn = document.getElementById('close-suggestions');

            if (!btn || !container || !content) return;

            let lastSuggestions = [];
            let selectedIndex = 0;

            function parseUtc(utcStr) {
                const s = utcStr?.endsWith('Z') ? utcStr : (utcStr + 'Z');
                return new Date(s);
            }
            function toInputValueLocal(d) {
                const pad = n => String(n).padStart(2, '0');
                const yyyy = d.getFullYear();
                const MM = pad(d.getMonth() + 1);
                const dd = pad(d.getDate());
                const hh = pad(d.getHours());
                const mm = pad(d.getMinutes());
                return `${yyyy}-${MM}-${dd}T${hh}:${mm}`;
            }
            function sameMinute(a, b) {
                return a.getFullYear() === b.getFullYear()
                    && a.getMonth() === b.getMonth()
                    && a.getDate() === b.getDate()
                    && a.getHours() === b.getHours()
                    && a.getMinutes() === b.getMinutes();
            }
            function formatDisplay(date) {
                try {
                    return new Intl.DateTimeFormat('fr-FR', {
                        weekday: 'short', year: 'numeric', month: '2-digit', day: '2-digit',
                        hour: '2-digit', minute: '2-digit'
                    }).format(date);
                } catch { return date.toLocaleString(); }
            }
            function getCurrentSlot() {
                const deb = document.getElementById('Prs_DateDebut')?.value;
                const fin = document.getElementById('Prs_DateFin')?.value;
                if (!deb || !fin) return null;
                const a = new Date(deb), b = new Date(fin);
                if (isNaN(a) || isNaN(b)) return null;
                return { start: a, end: b };
            }
            function computeDurationHours() {
                const select = document.getElementById('duration-select');
                if (select && select.value) return parseInt(select.value, 10) || 1;
                const cur = getCurrentSlot();
                if (cur) {
                    const h = Math.max(1, Math.round((cur.end - cur.start) / 3600000));
                    return h;
                }
                return 1;
            }

            function renderSuggestions(list) {
                content.innerHTML = '';
                if (!list || !list.length) {
                    content.innerHTML = '<div class="alert alert-warning mb-0">Aucune alternative disponible.</div>';
                    applyBtn?.setAttribute('disabled', 'disabled');
                    return;
                }

                // Liste Bootstrap pour limiter les ajouts de CSS
                const ul = document.createElement('ul');
                ul.className = 'list-group';

                list.forEach((s, idx) => {
                    const start = parseUtc(s.dateDebut);
                    const end = parseUtc(s.dateFin);

                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-start';
                    li.dataset.index = String(idx);
                    li.style.cursor = 'pointer';

                    const left = document.createElement('div');
                    left.className = 'me-3';
                    left.innerHTML = `
                        <div><strong>${formatDisplay(start)} → ${formatDisplay(end)}</strong></div>
                        <div class="text-muted" style="font-size:.9rem;">${s.raison || ''}</div>
                    `;

                    const right = document.createElement('div');
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-light text-dark';
                    badge.textContent = `Score ${s.score}`;
                    right.appendChild(badge);

                    li.appendChild(left);
                    li.appendChild(right);

                    li.addEventListener('click', () => selectIndex(idx));
                    ul.appendChild(li);
                });

                content.appendChild(ul);
                selectedIndex = 0;
                highlightSelected();
                applyBtn?.removeAttribute('disabled');
            }

                    function highlightSelected() {
          const rows = content.querySelectorAll('li.list-group-item');
          rows.forEach((r, i) => {
            const on = i === selectedIndex;
            r.classList.toggle('active', on);
            r.classList.toggle('border-success', on);
          });
        }

            function selectIndex(i) {
                if (!lastSuggestions.length) return;
                selectedIndex = Math.max(0, Math.min(i, lastSuggestions.length - 1));
                highlightSelected();
            }

            async function fetchSuggestions() {
                const ligneIdRaw = document.getElementById('ligne-select')?.value || '';
                const ligneId = parseInt(ligneIdRaw, 10);
                if (!ligneId) {
                    content.innerHTML = '<div class="alert alert-info mb-0">Veuillez d’abord sélectionner une ligne.</div>';
                    container.style.display = 'block';
                    return [];
                }

                const equipement = document.getElementById('Prs_Equipement')?.value || null;
                const duration = computeDurationHours();

                const body = {
                    LigneId: ligneId,
                    Equipement: equipement,
                    DurationHours: duration
                };

                const resp = await fetch('/api/ai-suggestions/suggest-slot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await resp.json().catch(() => ({}));
                if (!resp.ok || !data?.success) {
                    throw new Error(data?.message || 'Erreur lors de la récupération des suggestions');
                }
                return Array.isArray(data.suggestions) ? data.suggestions : [];
            }

            async function suggest() {
                try {
                    btn.classList.add('analyzing');
                    btn.disabled = true;
                    content.innerHTML = '<div class="text-muted">Analyse en cours...</div>';
                    container.style.display = 'block';

                    const raw = await fetchSuggestions();

                    // Exclure le créneau identique au courant
                    const cur = getCurrentSlot();
                    let filtered = raw;
                    if (cur) {
                        filtered = raw.filter(s => {
                            const sStart = parseUtc(s.dateDebut);
                            const sEnd = parseUtc(s.dateFin);
                            return !(sameMinute(cur.start, sStart) && sameMinute(cur.end, sEnd));
                        });
                    }

                    lastSuggestions = filtered.slice(0, 5);
                    renderSuggestions(lastSuggestions);
                } catch (e) {
                    console.error('[ROBIA][CLONE] Exception', e);
                    content.innerHTML = `<div class="alert alert-danger mb-0">Erreur ROBIA: ${(e && e.message) || e}</div>`;
                    container.style.display = 'block';
                } finally {
                    btn.classList.remove('analyzing');
                    btn.disabled = false;
                }
            }

            function applySelected() {
                if (!lastSuggestions.length) return;
                const s = lastSuggestions[selectedIndex];
                if (!s) return;

                const start = parseUtc(s.dateDebut);
                const end = parseUtc(s.dateFin);

                const deb = document.getElementById('Prs_DateDebut');
                const fin = document.getElementById('Prs_DateFin');
                if (deb && fin) {
                    deb.value = toInputValueLocal(start);
                    fin.value = toInputValueLocal(end);
                }
            }

            function rotateAlternative() {
                if (lastSuggestions.length > 1) {
                    selectedIndex = (selectedIndex + 1) % lastSuggestions.length;
                    highlightSelected();
                    return;
                }
                // Si une seule sugg, relancer pour tenter d’en obtenir d’autres
                suggest();
            }

            btn.addEventListener('click', suggest);
            applyBtn?.addEventListener('click', applySelected);
            altBtn?.addEventListener('click', rotateAlternative);
            closeBtn?.addEventListener('click', () => { container.style.display = 'none'; });

            // Auto-regénération si le panneau est ouvert et que les paramètres changent
            ['ligne-select', 'Prs_Equipement', 'duration-select', 'Prs_DateDebut', 'Prs_DateFin'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', () => {
                    if (container.style.display === 'block') suggest();
                });
            });
        })();
    </script>
}