<!-- CALENDRIER SANS ARRIÈRE-PLAN -->
@Html.Partial("_CalendarBlock")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <!-- Include JavaScript files for enhanced functionality -->
    <script src="~/js/file-upload.js" asp-append-version="true"></script>
    <script src="~/js/checklist-manager.js" asp-append-version="true"></script>

    <script>
        // Déterminer si l'utilisateur est admin ou validateur et s'il peut éditer
        const isAdminOrValidateur = @Json.Serialize(isAdminOrValidateur);
        const canEdit = @Json.Serialize(canEdit);

        // Variables globales
        const dateDebutInput = document.querySelector("#Prs_DateDebut");
        const dateFinInput = document.querySelector("#Prs_DateFin");
        const ligneSelect = document.querySelector("#ligne-select");

        // Sélecteurs spécifiques pour le mode semaine
        const hiddenDateDebutInput = document.querySelector("#hiddenDateDebut");
        const hiddenDateFinInput = document.querySelector("#hiddenDateFin");
        const weekInfoElem = document.querySelector("#weekInfo");
        const weekDaysElem = document.querySelector("#weekDays");
        const weekHighlightElem = document.querySelector("#weekHighlight");
        const selectedWeekInput = document.querySelector("#selectedWeek");

        // Variable pour la semaine sélectionnée (pour utilisateurs normaux)
        let currentWeekStart;

        // Initialisation du sélecteur de semaine pour les utilisateurs non-admin avec droits d'édition
        if (canEdit && !isAdminOrValidateur && weekInfoElem && weekDaysElem) {
            // Date de début actuelle pour initialiser la sélection de semaine
            currentWeekStart = getMonday(new Date(@Json.Serialize(Model.Prs.DateDebut)));

            // Initialisation de l'interface de sélection de semaine
            initWeekSelector();

            // Mise à jour initiale des champs cachés
            updateHiddenDateFields();
        }

        // Fonction pour obtenir le lundi d'une semaine donnée
        function getMonday(date) {
            const d = new Date(date);
            const day = d.getDay();
            const diff = d.getDate() - day + (day === 0 ? -6 : 1);
            return new Date(d.setDate(diff));
        }

        // Formater la date en texte français
        function formatDateFr(date) {
            const options = { day: 'numeric', month: 'long', year: 'numeric' };
            return date.toLocaleDateString('fr-FR', options);
        }

        // Formatage du nom du jour en français
        function getDayName(date) {
            return date.toLocaleDateString('fr-FR', { weekday: 'short' });
        }

        // Initialisation du sélecteur de semaine
        function initWeekSelector() {
            // Mettre à jour l'affichage de la semaine actuelle
            updateWeekDisplay();

            // Ajouter des écouteurs d'événements pour la navigation
            document.getElementById('prevWeek').addEventListener('click', () => {
                currentWeekStart.setDate(currentWeekStart.getDate() - 7);
                updateWeekDisplay();
            });

            document.getElementById('nextWeek').addEventListener('click', () => {
                currentWeekStart.setDate(currentWeekStart.getDate() + 7);
                updateWeekDisplay();
            });
        }

        // Mettre à jour l'affichage de la semaine
        function updateWeekDisplay() {
            if (!weekInfoElem || !weekDaysElem || !weekHighlightElem) return;

            // Mettre à jour l'info de la semaine
            const weekEnd = new Date(currentWeekStart);
            weekEnd.setDate(weekEnd.getDate() + 6); // Dimanche

            weekInfoElem.textContent = `Semaine ${getWeekNumber(currentWeekStart)} - ${currentWeekStart.getFullYear()}`;
            weekHighlightElem.textContent = `Semaine du ${formatDateFr(currentWeekStart)} au ${formatDateFr(weekEnd)}`;

            // Mettre à jour le champ caché avec la date du lundi
            if (selectedWeekInput) {
                selectedWeekInput.value = currentWeekStart.toISOString();
            }

            // Générer l'affichage des jours de la semaine
            weekDaysElem.innerHTML = '';

            for (let i = 0; i < 7; i++) {
                const day = new Date(currentWeekStart);
                day.setDate(day.getDate() + i);

                // Créer l'élément jour
                const dayElement = document.createElement('div');
                dayElement.className = 'week-day';

                const dayName = getDayName(day);
                const dayNumber = day.getDate();

                dayElement.innerHTML = `
                    <div class="day-name">${dayName}</div>
                    <div class="day-number">${dayNumber}</div>
                `;

                weekDaysElem.appendChild(dayElement);
            }

            // Mise à jour des champs cachés
            updateHiddenDateFields();
        }

        // Obtenir le numéro de semaine d'une date
        function getWeekNumber(date) {
            const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
            const dayNum = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - dayNum);
            const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
        }

        // Mettre à jour les champs cachés pour la semaine entière
        function updateHiddenDateFields() {
            if (!currentWeekStart || !hiddenDateDebutInput || !hiddenDateFinInput) return;

            // La période va du lundi 00:00:00 au lundi suivant 00:00:00
            const mondayStart = new Date(currentWeekStart);
            mondayStart.setHours(0, 0, 0, 0);

            const nextMonday = new Date(mondayStart);
            nextMonday.setDate(nextMonday.getDate() + 7); // Lundi suivant à 00:00:00

            // Mettre à jour les champs cachés (format ISO)
            hiddenDateDebutInput.value = mondayStart.toISOString().slice(0, 16);
            hiddenDateFinInput.value = nextMonday.toISOString().slice(0, 16);
        }

        // Gestion du sélecteur de couleur pour les admins/validateurs
        const colorPicker = document.querySelector('input[type="color"]');
        const colorText = document.querySelector('input[type="text"][name="Prs.CouleurPRS"]');
        const clearButton = document.getElementById('clearColor');

        if (colorPicker && colorText) {
            colorPicker.addEventListener('change', function() {
                colorText.value = this.value;
            });

            colorText.addEventListener('input', function() {
                if (this.value.match(/^#[0-9A-Fa-f]{6}$/)) {
                    colorPicker.value = this.value;
                }
            });

            if (clearButton) {
                clearButton.addEventListener('click', function() {
                    colorPicker.value = '#007bff';
                    colorText.value = '';
                });
            }
        }

        // =========== GESTION DES AFFECTATIONS PRS ===========
        const affectationsList = document.getElementById('affectationsList');
        const affectationsData = document.getElementById('affectationsData');
        const userSelect = document.getElementById('userSelect');
        const groupSelect = document.getElementById('groupSelect');
        const addUserBtn = document.getElementById('addUserBtn');
        const addGroupBtn = document.getElementById('addGroupBtn');

        let prsAffectations = [];

        // Initialiser avec les affectations existantes
        function initializeExistingAffectations() {
            const existingItems = document.querySelectorAll('.existing-affectation');
            existingItems.forEach(item => {
                const id = parseInt(item.dataset.id);
                const type = item.dataset.type;
                const nameElement = item.querySelector('strong');
                const name = nameElement ? nameElement.textContent.trim() : '';
                
                if (id && type && name) {
                    prsAffectations.push({ id, type, name, info: '' });
                }
            });
            updateAffectationsData();
        }

        function addAffectation(id, type, name, info) {
            // Vérifier si déjà ajouté
            if (prsAffectations.some(a => a.id === id && a.type === type)) {
                alert(`Cette ${type.toLowerCase()} est déjà affectée.`);
                return;
            }

            prsAffectations.push({ id, type, name, info });
            updateAffectationsList();
            updateAffectationsData();
        }

        function removeAffectation(id, type) {
            prsAffectations = prsAffectations.filter(a => !(a.id === id && a.type === type));
            updateAffectationsList();
            updateAffectationsData();
        }

        function updateAffectationsList() {
            if (!affectationsList) return;
            
            // Supprimer les éléments dynamiques mais garder les existants
            const dynamicItems = affectationsList.querySelectorAll('.dynamic-affectation');
            dynamicItems.forEach(item => item.remove());
            
            // Supprimer le message "aucune affectation" s'il existe
            const noAffectationsMsg = affectationsList.querySelector('.no-affectations');
            if (noAffectationsMsg && prsAffectations.length > 0) {
                noAffectationsMsg.remove();
            }

            // Ajouter les nouvelles affectations (qui ne sont pas dans les existantes)
            const existingAffectations = Array.from(document.querySelectorAll('.existing-affectation'));
            const existingIds = existingAffectations.map(item => ({
                id: parseInt(item.dataset.id),
                type: item.dataset.type
            }));

            prsAffectations.forEach(affectation => {
                // Vérifier si cette affectation n'est pas déjà dans les existantes
                const isExisting = existingIds.some(existing => 
                    existing.id === affectation.id && existing.type === affectation.type
                );
                
                if (!isExisting) {
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-center dynamic-affectation';
                    
                    const iconClass = affectation.type === 'Utilisateur' ? 'fa-user' : 'fa-users';
                    li.innerHTML = `
                        <div>
                            <i class="fas ${iconClass} me-2"></i>
                            <strong>${affectation.name}</strong>
                            ${affectation.info ? `<span class="text-muted">(${affectation.info})</span>` : ''}
                        </div>
                        ${canEdit ? `<button type="button" class="btn btn-sm btn-outline-danger remove-affectation" data-id="${affectation.id}" data-type="${affectation.type}">
                            <i class="fas fa-times"></i>
                        </button>` : ''}
                    `;
                    
                    affectationsList.appendChild(li);
                }
            });
        }

        function updateAffectationsData() {
            if (affectationsData) {
                // Combiner les affectations existantes et nouvelles
                const allAffectations = [];
                
                // Ajouter les existantes
                const existingItems = document.querySelectorAll('.existing-affectation');
                existingItems.forEach(item => {
                    allAffectations.push({
                        id: parseInt(item.dataset.id),
                        type: item.dataset.type,
                        name: item.querySelector('strong')?.textContent.trim() || '',
                        info: ''
                    });
                });
                
                // Ajouter les nouvelles (non existantes)
                prsAffectations.forEach(affectation => {
                    const isExisting = Array.from(existingItems).some(item => 
                        parseInt(item.dataset.id) === affectation.id && item.dataset.type === affectation.type
                    );
                    if (!isExisting) {
                        allAffectations.push(affectation);
                    }
                });
                
                affectationsData.value = JSON.stringify(allAffectations);
            }
        }

        // Event listeners pour les affectations
        if (canEdit && addUserBtn) {
            addUserBtn.addEventListener('click', function() {
                const selectedOption = userSelect.selectedOptions[0];
                if (selectedOption && selectedOption.value) {
                    const id = parseInt(selectedOption.value);
                    const type = selectedOption.dataset.type;
                    const name = selectedOption.dataset.name;
                    const service = selectedOption.dataset.service;
                    
                    addAffectation(id, type, name, service);
                    userSelect.value = '';
                }
            });
        }

        if (canEdit && addGroupBtn) {
            addGroupBtn.addEventListener('click', function() {
                const selectedOption = groupSelect.selectedOptions[0];
                if (selectedOption && selectedOption.value) {
                    const id = parseInt(selectedOption.value);
                    const type = selectedOption.dataset.type;
                    const name = selectedOption.dataset.name;
                    const count = selectedOption.dataset.count;
                    
                    addAffectation(id, type, name, `${count} membres`);
                    groupSelect.value = '';
                }
            });
        }

        // Event listener pour supprimer des affectations
        if (canEdit && affectationsList) {
            affectationsList.addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-affectation') || e.target.closest('.remove-affectation')) {
                    const button = e.target.closest('.remove-affectation');
                    const id = parseInt(button.dataset.id);
                    const type = button.dataset.type;
                    
                    if (button.closest('.existing-affectation')) {
                        // Pour les affectations existantes, juste les cacher
                        button.closest('.existing-affectation').style.display = 'none';
                    } else {
                        // Pour les nouvelles affectations, les supprimer de la liste
                        removeAffectation(id, type);
                    }
                }
            });
        }

        // =========== GESTION DES LIENS DE DOSSIERS ===========
        const folderLinksList = document.getElementById('folderLinksList');
        const prsFolderLinksData = document.getElementById('prsFolderLinksData');
        const folderPathInput = document.getElementById('folderPath');
        const folderDescriptionInput = document.getElementById('folderDescription');
        const addFolderBtn = document.getElementById('addFolderBtn');

        let folderLinks = [];

        // Initialiser avec les liens existants
        function initializeExistingFolderLinks() {
            const existingItems = document.querySelectorAll('.existing-folder-link');
            existingItems.forEach(item => {
                const path = item.dataset.path;
                const description = item.dataset.description || '';
                
                if (path) {
                    folderLinks.push({ Chemin: path, Description: description });
                }
            });
            updateFolderLinksData();
        }

        function addFolderLink(path, description) {
            if (!path.trim()) {
                alert('Le chemin du dossier est obligatoire.');
                return;
            }

            // Vérifier si déjà ajouté
            if (folderLinks.some(link => link.Chemin === path)) {
                alert('Ce lien de dossier existe déjà.');
                return;
            }

            folderLinks.push({ Chemin: path, Description: description });
            updateFolderLinksList();
            updateFolderLinksData();
            
            // Vider les champs
            if (folderPathInput) folderPathInput.value = '';
            if (folderDescriptionInput) folderDescriptionInput.value = '';
        }

        function removeFolderLink(path) {
            folderLinks = folderLinks.filter(link => link.Chemin !== path);
            updateFolderLinksList();
            updateFolderLinksData();
        }

        function updateFolderLinksList() {
            if (!folderLinksList) return;
            
            // Supprimer les éléments dynamiques mais garder les existants
            const dynamicItems = folderLinksList.querySelectorAll('.dynamic-folder-link');
            dynamicItems.forEach(item => item.remove());
            
            // Supprimer le message "aucun lien" s'il existe
            const noLinksMsg = folderLinksList.querySelector('.no-folder-links');
            if (noLinksMsg && folderLinks.length > 0) {
                noLinksMsg.remove();
            }

            // Ajouter les nouveaux liens (qui ne sont pas dans les existants)
            const existingLinks = Array.from(document.querySelectorAll('.existing-folder-link'));
            const existingPaths = existingLinks.map(item => item.dataset.path);

            folderLinks.forEach(link => {
                if (!existingPaths.includes(link.Chemin)) {
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-center dynamic-folder-link';
                    
                    li.innerHTML = `
                        <div class="folder-link-info">
                            <div>
                                <i class="fas fa-folder-open me-2 text-warning"></i>
                                <strong>${link.Chemin}</strong>
                            </div>
                            ${link.Description ? `<small class="text-muted">${link.Description}</small>` : ''}
                        </div>
                        <div class="folder-link-actions">
                            <a href="file://${link.Chemin}" class="btn btn-sm btn-outline-primary me-1" target="_blank" title="Ouvrir le dossier">
                                <i class="fas fa-external-link-alt"></i>
                            </a>
                            ${canEdit ? `<button type="button" class="btn btn-sm btn-outline-danger remove-folder-link" data-path="${link.Chemin}">
                                <i class="fas fa-times"></i>
                            </button>` : ''}
                        </div>
                    `;
                    
                    folderLinksList.appendChild(li);
                }
            });
        }

        function updateFolderLinksData() {
            if (prsFolderLinksData) {
                // Combiner les liens existants et nouveaux
                const allLinks = [];
                
                // Ajouter les existants
                const existingItems = document.querySelectorAll('.existing-folder-link');
                existingItems.forEach(item => {
                    if (item.style.display !== 'none') {
                        allLinks.push({
                            Chemin: item.dataset.path,
                            Description: item.dataset.description || ''
                        });
                    }
                });
                
                // Ajouter les nouveaux (non existants)
                folderLinks.forEach(link => {
                    const isExisting = Array.from(existingItems).some(item => 
                        item.dataset.path === link.Chemin
                    );
                    if (!isExisting) {
                        allLinks.push(link);
                    }
                });
                
                prsFolderLinksData.value = JSON.stringify(allLinks);
            }
        }

        // Event listeners pour les liens de dossiers
        if (canEdit && addFolderBtn) {
            addFolderBtn.addEventListener('click', function() {
                const path = folderPathInput ? folderPathInput.value.trim() : '';
                const description = folderDescriptionInput ? folderDescriptionInput.value.trim() : '';
                
                addFolderLink(path, description);
            });
            
            // Permettre l'ajout avec la touche Entrée
            [folderPathInput, folderDescriptionInput].forEach(input => {
                if (input) {
                    input.addEventListener('keypress', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            addFolderBtn.click();
                        }
                    });
                }
            });
        }

        // Event listener pour supprimer des liens de dossiers
        if (canEdit && folderLinksList) {
            folderLinksList.addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-folder-link') || e.target.closest('.remove-folder-link')) {
                    const button = e.target.closest('.remove-folder-link');
                    const path = button.dataset.path;
                    
                    if (button.closest('.existing-folder-link')) {
                        // Pour les liens existants, juste les cacher
                        button.closest('.existing-folder-link').style.display = 'none';
                        updateFolderLinksData();
                    } else {
                        // Pour les nouveaux liens, les supprimer de la liste
                        removeFolderLink(path);
                    }
                }
            });
        }

        // Initialisation au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            initializeExistingAffectations();
            initializeExistingFolderLinks();
        });

        // Validation du formulaire
        document.querySelector("#edit-form")?.addEventListener("submit", function (e) {
            if (isAdminOrValidateur && dateDebutInput && dateFinInput) {
                // Validation des dates pour admin/validateur
                const dateDebut = new Date(dateDebutInput.value);
                const dateFin = new Date(dateFinInput.value);

                if (dateFin <= dateDebut) {
                    e.preventDefault();
                    alert('La date de début doit être antérieure à la date de fin.');
                    return false;
                }
            }

            // Vérification que la ligne est sélectionnée
            if (ligneSelect && !ligneSelect.value) {
                e.preventDefault();
                alert('Veuillez sélectionner une ligne.');
                ligneSelect.focus();
                return false;
            }
        });
    </script>
}