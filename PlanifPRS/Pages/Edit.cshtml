                        {
                            <div class="row">
                                <div class="col-md-6">
                                    <!-- Sélection utilisateur -->
                                    <div class="form-group mb-3">
                                        <label class="form-label">
                                            <i class="fas fa-user me-1"></i>
                                            Ajouter un utilisateur
                                        </label>
                                        <div class="input-group">
                                            <select id="userSelect" class="form-select">
                                                <option value="">Sélectionner un utilisateur...</option>
                                                @foreach (var user in Model.Utilisateurs.OrderBy(u => u.Nom).ThenBy(u => u.Prenom))
                                                {
                                                    <option value="@user.Id" data-type="Utilisateur" data-name="@user.Prenom @user.Nom" data-service="@user.Service">
                                                        @user.Nom @user.Prenom (@user.Service)
                                                    </option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-outline-primary" id="addUserBtn">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <!-- Sélection groupe -->
                                    <div class="form-group mb-3">
                                        <label class="form-label">
                                            <i class="fas fa-users me-1"></i>
                                            Ajouter un groupe
                                        </label>
                                        <div class="input-group">
                                            <select id="groupSelect" class="form-select">
                                                <option value="">Sélectionner un groupe...</option>
                                                @foreach (var groupe in Model.GroupesUtilisateurs.OrderBy(g => g.NomGroupe))
                                                {
                                                    <option value="@groupe.Id" data-type="Groupe" data-name="@groupe.NomGroupe" data-count="@groupe.Membres.Count">
                                                        @groupe.NomGroupe (@groupe.Membres.Count membres)
                                                    </option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-outline-success" id="addGroupBtn">
                                                <i class="fas fa-plus"></i>
                                            </button>
