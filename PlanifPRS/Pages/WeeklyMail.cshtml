/* ====================== OUTILS ====================== */
function formatPrsDate(d){
    const date=new Date(d);
    const days=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
    return `${days[date.getDay()]} ${date.getDate()}/${date.getMonth()+1}`;
}
function getWeekDateRange(year,week){
    const jan4=new Date(year,0,4);
    const jan4Day=jan4.getDay()||7;
    const firstMonday=new Date(jan4.getTime()-(jan4Day-1)*86400000);
    const start=new Date(firstMonday.getTime()+(week-1)*7*86400000);
    const end=new Date(start.getTime()+6*86400000);
    return `${start.getDate()}/${start.getMonth()+1} au ${end.getDate()}/${end.getMonth()+1}`;
}
function determineSecteurFromPRS(p){
    const ligne = (p.ligne || p.Ligne || '').toLowerCase();
    if(p.secteur && p.secteur.trim()) return p.secteur;
    for(const s of availableSecteurs){
        if(ligne.includes((s.nom||'').toLowerCase())) return s.nom;
    }
    if(/verni|pack/i.test(ligne)) return 'FINITION';
    if(/nxt|cms/i.test(ligne)) return 'CMS';
    return 'AUTRES';
}
function getSecteurColor(n){
    const map={
        'CMS':'#3498db','FINITION':'#27ae60','AUTO':'#e67e22','PRODUCTION':'#8e44ad',
        'MAINTENANCE':'#e74c3c','QUALITE':'#1abc9c','LOGISTIQUE':'#f1c40f',
        'PLANNING':'#34495e','ADMINISTRATIF':'#85929e','FORMATION':'#af7ac5',
        'SECURITE':'#dc7633','ENVIRONNEMENT':'#82e0aa','AUTRES':'#95a5a6'
    };
    const p=map[n]||'#95a5a6';
    return {primary:p, light:p+'20'};
}
function updateStats(prs,group){
    document.getElementById('totalPrs').textContent=prs.length;
    document.getElementById('totalLines').textContent=new Set(prs.map(p=>(p.ligne||p.Ligne))).size;
    document.getElementById('totalDays').textContent=new Set(prs.map(p=>formatPrsDate(p.dateDebut||p.DateDebut))).size;
    document.getElementById('totalSections').textContent= group ? new Set(prs.map(p=>determineSecteurFromPRS(p))).size : 1;
}

