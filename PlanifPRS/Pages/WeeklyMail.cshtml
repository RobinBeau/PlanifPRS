function tryOpenInOutlook() {
    let raw=document.getElementById('mailTo').value?.trim();
    if(!raw){
        const collected=collectAllEmails();
        if(collected.length){
            raw=collected.join(', ');
            document.getElementById('mailTo').value=raw;
        }
    }
    if(!raw){ showToast('Pas de destinataires','warning'); return; }
    const toList=raw.split(/[;,]+/).map(x=>x.trim()).filter(Boolean);
    const valid=toList.filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    const finalList=valid.length?valid:toList;
    const toHeader=finalList.join(', ');

    const ccRaw=document.getElementById('mailCc').value?.trim();
    const ccList=(ccRaw||'').split(/[;,]+/).map(x=>x.trim()).filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    const ccHeader=ccList.join(', ');

    const subject=document.getElementById('mailSubject').value;
    if(!subject){ showToast('Génère d\'abord le mail','warning'); return; }

    const [year,wn]=document.getElementById('selectedWeek').value.split('-W');
    const wk=parseInt(wn);
    const incl=document.getElementById('includeWarnings').checked;
    const group=document.getElementById('groupBySection').checked;
    const prs=window.weeklyPrsData||[];
    const body=generateFormattedTextEmail(prs,wk,year,incl,group);
    const payload=`subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    if(payload.length>MAILTO_LIMIT){ showToast('Trop volumineux (mailto)','warning'); showAlternativeOptions(); return; }
    const link=`mailto:${encodeURIComponent(toHeader)}?${ccHeader?`cc=${encodeURIComponent(ccHeader)}&`:''}${payload}`;
    const a=document.createElement('a'); a.href=link; document.body.appendChild(a); a.click(); a.remove();
    showToast('Ouverture client mail...','success');
}

