function populateEmailFields(force=false){
    const emails = collectAllEmails();
    const field = document.getElementById('mailTo');
    if(!field) return;
    const autoReplace = document.getElementById('autoReplaceEmails')?.checked;
    let currentRaw = field.value || '';
    let existing = currentRaw
        .split(/[;, \n]+/)
        .map(e=>e.trim())
        .filter(e=>e && (EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e)));
    if(existing.length===0){
        field.value = emails.join(', ');
        return;
    }
    const existingLower = existing.map(e=>e.toLowerCase());
    const missing = emails.filter(e=>!existingLower.includes(e.toLowerCase()));
    if(autoReplace || force){
        const targetLower = emails.map(e=>e.toLowerCase());
        const allIn = existingLower.every(e=>targetLower.includes(e));
        if(allIn && (existingLower.length < targetLower.length || autoReplace)){
            field.value = emails.join(', ');
            return;
        }
    }
    if(missing.length){
        field.value = existing.concat(missing).join(', ');
    }
}
