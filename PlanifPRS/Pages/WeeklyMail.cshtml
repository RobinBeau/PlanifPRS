@page
@model PlanifPRS.Pages.WeeklyMailModel
@{
    ViewData["Title"] = "Mail hebdo";
}

<style>
    #userInfo { animation: fadeInUp .3s ease-out; }
    @@keyframes fadeInUp {
        from { opacity:0; transform: translateY(10px); }
        to { opacity:1; transform: translateY(0); }
    }
    .modal-body .row .col-md-6 {
        border-left:3px solid #007bff;
        padding-left:10px;
    }
</style>

<div class="row">
    <div class="col-12">
        <div class="card shadow-lg border-0">
            <div class="card-header" style="background:linear-gradient(135deg,#2c3e50,#34495e);color:#fff;border-radius:15px 15px 0 0;">
                <h2 class="mb-0"><i class="fas fa-envelope me-2"></i>Génération du mail hebdomadaire</h2>
                <p class="mb-0 opacity-75">Synthèse automatique des PRS planifiées</p>
            </div>
            <div class="card-body" style="background:#f8f9fa;padding:30px;">

                <!-- Sélection semaines -->
                <div class="row mb-4">
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#3498db,#2980b9);border-radius:15px;">
                            <div class="card-body text-white">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar-week me-1"></i>Sélectionner la semaine (ou 2 semaines)
                                </label>

                                <div class="input-group mb-2">
                                    <input type="week" id="selectedWeek" class="form-control border-0 shadow-sm" value="@Model.CurrentWeek" style="border-radius:10px;">
                                    <button class="btn btn-light border-0 shadow-sm ms-2" type="button" onclick="loadWeekData()" style="border-radius:10px;">
                                        <i class="fas fa-sync-alt me-1"></i>Charger
                                    </button>
                                </div>

                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="dualWeekMode" onchange="toggleSecondWeek()">
                                    <label class="form-check-label" for="dualWeekMode">Sélection 2 semaines</label>
                                </div>

                                <div id="secondWeekWrapper" class="mb-2" style="display:none;">
                                    <div class="input-group">
                                        <input type="week" id="selectedWeek2" class="form-control border-0 shadow-sm">
                                        <button class="btn btn-light border-0 shadow-sm ms-2" type="button" onclick="loadWeekData()" style="border-radius:10px;">
                                            <i class="fas fa-sync-alt me-1"></i>Recharger 2 sem.
                                        </button>
                                    </div>
                                    <small class="opacity-75">Les deux semaines seront fusionnées.</small>
                                </div>

                                <small class="opacity-75">
                                    Semaine actuelle : S@(Model.WeekNumber) | Semaine prochaine : S@(Model.NextWeekNumber)
                                </small>

                                <div class="mt-3">
                                    <button type="button" class="btn btn-outline-light btn-sm me-2" onclick="selectCurrentWeek()" style="border-radius:10px;">
                                        <i class="fas fa-calendar-day me-1"></i>Semaine actuelle (S@(Model.WeekNumber))
                                    </button>
                                    <button type="button" class="btn btn-outline-light btn-sm" onclick="selectNextWeek()" style="border-radius:10px;">
                                        <i class="fas fa-calendar-plus me-1"></i>Semaine prochaine (S@(Model.NextWeekNumber))
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Options -->
                    <div class="col-lg-5 mt-3 mt-lg-0">
                        <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#27ae60,#229954);border-radius:15px;">
                            <div class="card-body text-white">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-cog me-1"></i>Options
                                </label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="includeWarnings" checked>
                                    <label class="form-check-label" for="includeWarnings">Inclure les avertissements / notes</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="groupBySection" checked>
                                    <label class="form-check-label" for="groupBySection">Grouper par secteur</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="autoReplaceEmails" checked>
                                    <label class="form-check-label" for="autoReplaceEmails">Toujours remplacer les destinataires</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info semaine -->
                <div id="weekInfo" class="alert border-0 shadow-sm mb-4"
                     style="background:linear-gradient(135deg,#ecf0f1,#bdc3c7);border-radius:15px;">
                    <i class="fas fa-info-circle me-2 text-primary"></i>
                    <span id="weekInfoText" class="text-dark fw-bold">
                        Prêt à générer le mail pour la semaine actuelle (S@(Model.WeekNumber))
                    </span>
                </div>

                <!-- Actions -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#34495e,#2c3e50);border-radius:15px;">
                            <div class="card-body text-center">
                                <button type="button" class="btn btn-light btn-lg me-2 shadow-sm"
                                        onclick="generateMail()" style="border-radius:15px;border:none;">
                                    <i class="fas fa-magic me-2"></i>Générer le mail
                                </button>

                                <button type="button" class="btn btn-success btn-lg me-2 shadow-sm"
                                        onclick="downloadEMLFile()" id="emlBtn" disabled
                                        style="border-radius:15px;border:none;">
                                    <i class="fas fa-envelope-open me-2"></i>Télécharger .eml
                                </button>

                                <div class="btn-group me-2">
                                    <button type="button" class="btn btn-info btn-lg shadow-sm" id="outlookBtn"
                                            onclick="tryOpenInOutlook()" disabled
                                            style="border-radius:15px 0 0 15px;border:none;">
                                        <i class="fas fa-paper-plane me-2"></i>Envoyer
                                    </button>
                                    <button type="button" class="btn btn-success btn-lg dropdown-toggle dropdown-toggle-split shadow-sm"
                                            id="outlookDropdown" data-bs-toggle="dropdown" disabled
                                            style="border-radius:0 15px 15px 0;border:none;">
                                        <span class="visually-hidden">Options</span>
                                    </button>
                                    <ul class="dropdown-menu shadow-lg border-0" style="border-radius:15px;">
                                        <li><a class="dropdown-item" href="#" onclick="tryOpenInOutlook()">
                                            <i class="fas fa-external-link-alt me-2 text-primary"></i>Essayer mailto</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="copyTextAndShowInstructions()">
                                            <i class="fas fa-copy me-2 text-success"></i>Copier texte + instructions</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="copyHTMLAndShowInstructions()">
                                            <i class="fas fa-palette me-2 text-info"></i>Copier HTML + instructions</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="downloadHTMLFile()">
                                            <i class="fas fa-download me-2 text-warning"></i>Télécharger HTML</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="downloadEMLFile()">
                                            <i class="fas fa-envelope-open me-2 text-success"></i>Télécharger .eml</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="#" onclick="showManualInstructions()">
                                            <i class="fas fa-question-circle me-2 text-secondary"></i>Aide</a></li>
                                    </ul>
                                </div>

                                <button type="button" class="btn btn-outline-light shadow-sm" id="copyBtn"
                                        onclick="copyToClipboard()" disabled style="border-radius:15px;">
                                    <i class="fas fa-copy me-2"></i>Copier HTML
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Alerte mailto -->
                <div id="mailtoLimitAlert" class="d-none">
                    <div class="alert alert-warning border-0 shadow-sm" style="border-radius:15px;">
                        <h6><i class="fas fa-exclamation-triangle me-2"></i>Mail volumineux</h6>
                        <p class="mb-2">Trop gros pour ouverture directe Outlook.</p>
                        <div class="d-grid gap-2 d-md-flex">
                            <button class="btn btn-success btn-sm" onclick="copyTextAndShowInstructions()">
                                <i class="fas fa-copy me-1"></i>Copier texte</button>
                            <button class="btn btn-info btn-sm" onclick="generateShortVersion()">
                                <i class="fas fa-compress me-1"></i>Version courte</button>
                            <button class="btn btn-secondary btn-sm" onclick="downloadHTMLFile()">
                                <i class="fas fa-download me-1"></i>Télécharger</button>
                        </div>
                    </div>
                </div>

                <!-- Aperçu -->
                <div id="mailPreview" class="d-none">
                    <div class="card border-0 shadow-lg" style="background:#fff;border-radius:20px;border:1px solid #dee2e6;">
                        <div class="card-header border-0 text-white"
                             style="background:linear-gradient(135deg,#495057,#6c757d);border-radius:20px 20px 0 0;">
                            <h5 class="mb-0">
                                <i class="fas fa-eye me-2"></i>Aperçu du mail
                                <span id="mailSizeIndicator" class="badge ms-2" style="font-size:11px;"></span>
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>À :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailTo" class="form-control border-0 shadow-sm"
                                           placeholder="destinataires@exemple.com" style="border-radius:10px;">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>Cc :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailCc" class="form-control border-0 shadow-sm"
                                           placeholder="responsables@exemple.com" style="border-radius:10px;">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>Objet :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailSubject" class="form-control border-0 shadow-sm"
                                           readonly style="border-radius:10px;background:#f8f9fa;">
                                </div>
                            </div>
                            <div class="border rounded shadow-sm p-4"
                                 style="background:#f8f9fa;border-radius:15px;border:1px solid #dee2e6;">
                                <div id="mailContent"
                                     style="font-family:'Segoe UI',sans-serif;background:#fff;padding:20px;border-radius:10px;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div id="mailStats" class="d-none mt-4">
                    <div class="row text-center">
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#2c3e50,#34495e);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalPrs">0</h4><small>PRS planifiées</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#3498db,#2980b9);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalLines">0</h4><small>Lignes utilisées</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#27ae60,#229954);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalDays">0</h4><small>Jours distincts</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#7f8c8d,#95a5a6);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalSections">0</h4><small>Secteurs actifs</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="weekUsersZone"></div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ====================== CONSTANTES & ETAT ====================== */
const currentWeek = '@Model.CurrentWeek';
const nextWeek = '@Model.NextWeek';
const currentWeekNumber = @Model.WeekNumber;
const nextWeekNumber = @Model.NextWeekNumber;
const MAILTO_LIMIT = 4500;
const ALWAYS_INCLUDE_EMAILS = ["direction@entreprise.com","qualite@entreprise.com"];

let availableSecteurs = [];
let weeklyUsers = { TotalUsers:0, AllEmails:[], EmailsFormatted:'', UsersByService:[] };

/* Regex Email */
        const EMAIL_REGEX_STRICT   = /^[A-Z0-9._%+-]+@@[A-Z0-9.-]+\.[A-Z]{2,}$/i;
        const EMAIL_REGEX_INTERNAL = /^[A-Z0-9._%+-]+@@[A-Z0-9.-]+$/i;
        const EMAIL_TOKEN_FINDER   = /[A-Z0-9._%+-]+@@[A-Z0-9.-]+\.[A-Z]{1,}/ig;

/* ====================== UTIL SEMAINES ====================== */
function parseWeekString(weekStr){
    if(!weekStr || !/^\d{4}-W\d{2}$/.test(weekStr)) return null;
    const [y,w] = weekStr.split('-W');
    return {year: parseInt(y,10), week: parseInt(w,10)};
}
function getMondayOfISOWeek(year, week){
    const jan4 = new Date(Date.UTC(year,0,4));
    const dayOfWeek = jan4.getUTCDay() || 7;
    const isoWeek1Monday = new Date(jan4.getTime() - (dayOfWeek - 1)*86400000);
    return new Date(isoWeek1Monday.getTime() + (week - 1)*7*86400000);
}
function endOfWeekFromMonday(mon){ return new Date(mon.getTime() + 6*86400000); }
function formatDateFR(d){ return d.toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'}); }

function buildWeeksArray(){
    const w1 = document.getElementById('selectedWeek')?.value;
    const dual = document.getElementById('dualWeekMode')?.checked;
    if(!dual) return w1 ? [w1] : [];
    const w2 = document.getElementById('selectedWeek2')?.value;
    if(!w1) return [];
    if(!w2) return [w1];
    return [w1,w2].sort();
}
function computeGlobalWeekRange(weeksArr){
    if(!weeksArr.length) return null;
    let minMon=null, maxSun=null;
    let labels=[];
    weeksArr.forEach(ws=>{
        const p=parseWeekString(ws);
        if(!p) return;
        const mon=getMondayOfISOWeek(p.year,p.week);
        const sun=endOfWeekFromMonday(mon);
        if(!minMon || mon < minMon) minMon = mon;
        if(!maxSun || sun > maxSun) maxSun = sun;
        labels.push(p);
    });
    labels.sort((a,b)=>(a.year-b.year)||(a.week-b.week));
    return {monday:minMon,sunday:maxSun,labelWeeks:labels};
}
function buildWeeksLabelForHeader(weeksArr){
    const parsed=weeksArr.map(parseWeekString).filter(Boolean)
        .sort((a,b)=>(a.year-b.year)||(a.week-b.week));
    if(!parsed.length) return '';
    if(parsed.length===1) {
        const p=parsed[0];
        return `S${p.week} • ${getWeekDateRange(p.year,p.week)}`;
    }
    const first=parsed[0], last=parsed[parsed.length-1];
    if(first.year===last.year) return `S${first.week}–S${last.week} ${first.year}`;
    return `S${first.week}/${first.year}–S${last.week}/${last.year}`;
}
function buildSubjectDateRangeLabel(weeksArr){
    const r = computeGlobalWeekRange(weeksArr);
    if(!r) return '';
    return `${formatDateFR(r.monday)} au ${formatDateFR(r.sunday)}`;
}
function buildSubjectFromWeeks(weeksArr){
    if(!weeksArr.length) return 'Planning PRS';
    const r = computeGlobalWeekRange(weeksArr);
    if(!r) return 'Planning PRS';
    const first = r.labelWeeks[0];
    const last  = r.labelWeeks[r.labelWeeks.length-1];
    let wkLabel;
    if(first.year===last.year) wkLabel = (first.week===last.week) ? `S${first.week}` : `S${first.week}–S${last.week}`;
    else wkLabel = `S${first.week}/${first.year}–S${last.week}/${last.year}`;
    return `Planning PRS ${wkLabel} - Semaine du ${formatDateFR(r.monday)} au ${formatDateFR(r.sunday)}`;
}
function toggleSecondWeek(){
    const dual=document.getElementById('dualWeekMode').checked;
    const wrap=document.getElementById('secondWeekWrapper');
    wrap.style.display = dual ? '' : 'none';
    if(dual && !document.getElementById('selectedWeek2').value){
        const w1=document.getElementById('selectedWeek').value;
        const p=parseWeekString(w1);
        if(p){
            let nextW=p.week+1;
            let nextY=p.year;
            if(nextW>53){ nextW=1; nextY++; }
            document.getElementById('selectedWeek2').value = `${nextY}-W${String(nextW).padStart(2,'0')}`;
        }
    }
    updateWeekInfo();
    loadWeekData();
}

/* ====================== UTILISATEURS / NORMALISATION ====================== */
function normalizeSingleUsers(raw){
    if(!raw || typeof raw!=='object') return {
        TotalUsers:0, AllEmails:[], EmailsFormatted:'', UsersByService:[]
    };
    const out = {
        TotalUsers:  raw.TotalUsers ?? raw.totalUsers ?? 0,
        AllEmails:   raw.AllEmails ?? raw.allEmails ?? [],
        EmailsFormatted: raw.EmailsFormatted ?? raw.emailsFormatted ?? '',
        UsersByService: raw.UsersByService ?? raw.usersByService ?? raw.services ?? []
    };
    if(Array.isArray(out.UsersByService)){
        out.UsersByService = out.UsersByService.map(s=>{
            const serviceName = s.Service || s.service || s.Nom || s.nom || 'Inconnu';
            let users = s.Utilisateurs || s.utilisateurs || s.users || s.Users || [];
            if(!Array.isArray(users) && typeof users==='object') users=Object.values(users);
            users = users.map(u=>({
                Prenom: u.Prenom || u.prenom || u.FirstName || u.firstName || '',
                Nom:    u.Nom || u.nom || u.LastName || u.lastName || '',
                Email:  u.Email || u.email || u.mail || ''
            }));
            return { Service: serviceName, Utilisateurs: users };
        });
    } else {
        out.UsersByService=[];
    }
    if(!out.AllEmails.length && out.UsersByService.length){
        const tmp=[];
        out.UsersByService.forEach(s=>s.Utilisateurs.forEach(u=>{
            if(u.Email && !tmp.includes(u.Email)) tmp.push(u.Email);
        }));
        out.AllEmails = tmp;
    }
    if(!out.TotalUsers){
        out.TotalUsers = out.UsersByService.reduce((a,s)=>a + s.Utilisateurs.length, 0);
    }
    return out;
}
function mergeUsers(normalizedArray){
    const merged = {
        TotalUsers:0,
        AllEmails:[],
        EmailsFormatted:'',
        UsersByService:[]
    };
    const emailSet = new Set();
    const serviceMap = new Map();
    normalizedArray.forEach(n=>{
        if(!n) return;
        (n.AllEmails||[]).forEach(e=>{ if(e) emailSet.add(e.toLowerCase()); });
        (n.UsersByService||[]).forEach(s=>{
            if(!serviceMap.has(s.Service))
                serviceMap.set(s.Service, { Service:s.Service, Utilisateurs:[], _lower:new Set() });
            const entry=serviceMap.get(s.Service);
            s.Utilisateurs.forEach(u=>{
                const em = u.Email?.toLowerCase();
                if(em && !entry._lower.has(em)){
                    entry._lower.add(em);
                    entry.Utilisateurs.push(u);
                }
            });
        });
    });
    merged.AllEmails = Array.from(emailSet);
    merged.UsersByService = Array.from(serviceMap.values()).map(v=>({ Service:v.Service, Utilisateurs:v.Utilisateurs }));
    merged.TotalUsers = merged.UsersByService.reduce((a,s)=>a + s.Utilisateurs.length, 0);
    merged.EmailsFormatted = merged.UsersByService
        .flatMap(s=>s.Utilisateurs.map(u=>`${u.Prenom} ${u.Nom} <${u.Email}>`))
        .join('; ');
    return merged;
}
function ensureWeeklyUsersShape(){
    if(!weeklyUsers || typeof weeklyUsers!=='object')
        weeklyUsers = { TotalUsers:0, AllEmails:[], EmailsFormatted:'', UsersByService:[] };
    if(!Array.isArray(weeklyUsers.AllEmails)) weeklyUsers.AllEmails=[];
    if(!Array.isArray(weeklyUsers.UsersByService)) weeklyUsers.UsersByService=[];
    weeklyUsers.TotalUsers ||= 0;
    weeklyUsers.EmailsFormatted ||= '';
}

/* ====================== EXTRACTION EMAILS ====================== */
function extractEmailsFromFormatted(formatted){
    if(!formatted) return [];
    const angled = formatted.match(/<([^>]+)>/g);
    if(angled){
        return angled.map(m=>m.replace(/[<>]/g,'').trim())
                     .filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    }
    return formatted.split(/[;, \n]+/)
        .map(e=>e.trim())
        .filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
}
function reconstructEmailsFromUsersByService(list){
    if(!Array.isArray(list)) return [];
    const acc=[];
    list.forEach(s=> (s.Utilisateurs||[]).forEach(u=>{
        const e=u.Email;
        if(e && (EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e)) && !acc.includes(e))
            acc.push(e);
    }));
    return acc;
}
function collectAllEmails(){
    ensureWeeklyUsersShape();
    let raw = [];
    if(weeklyUsers.AllEmails.length){
        raw.push(...weeklyUsers.AllEmails);
    } else if(weeklyUsers.EmailsFormatted){
        raw.push(...extractEmailsFromFormatted(weeklyUsers.EmailsFormatted));
    } else if(weeklyUsers.UsersByService.length){
        raw.push(...reconstructEmailsFromUsersByService(weeklyUsers.UsersByService));
    } else {
        try {
            const matches = JSON.stringify(weeklyUsers).match(EMAIL_TOKEN_FINDER);
            if(matches) raw.push(...matches);
        } catch {}
    }
    raw = raw
        .map(x=>x && x.toString().trim())
        .filter(Boolean)
        .flatMap(x=>x.split(/[;,]+/))
        .map(x=>x.trim())
        .filter(Boolean);
    const dedup=[];
    raw.forEach(r=>{ if(!dedup.includes(r)) dedup.push(r); });
    let strictValid = dedup.filter(e=>EMAIL_REGEX_STRICT.test(e));
    const internal = dedup.filter(e=>!EMAIL_REGEX_STRICT.test(e) && EMAIL_REGEX_INTERNAL.test(e));
    if(!strictValid.length && internal.length) strictValid = internal;
    if(!strictValid.length && dedup.length) strictValid = dedup;
    ALWAYS_INCLUDE_EMAILS.forEach(f=>{
        if(!strictValid.some(e=>e.toLowerCase()===f.toLowerCase()))
            strictValid.push(f);
    });
    return strictValid;
}

/* ====================== INIT ====================== */
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('selectedWeek').value = currentWeek;
    updateWeekInfo();
    loadSecteurs().then(loadWeekData);
    document.getElementById('selectedWeek').addEventListener('change', ()=>{ updateWeekInfo(); loadWeekData(); });
    const w2 = document.getElementById('selectedWeek2');
    if(w2) w2.addEventListener('change', ()=>{ updateWeekInfo(); loadWeekData(); });
});

/* ====================== APPELS API ====================== */
async function fetchWeekUsersSingle(weekStr){
    const r = await fetch(`/api/events/week-users?week=${encodeURIComponent(weekStr)}`);
    if(!r.ok) throw new Error('week-users '+weekStr+' HTTP '+r.status);
    return await r.json();
}
async function fetchWeekPrsSingle(weekStr){
    const r = await fetch(`/api/events/week?week=${encodeURIComponent(weekStr)}`);
    if(!r.ok) throw new Error('week '+weekStr+' HTTP '+r.status);
    return await r.json();
}
async function loadSecteurs(){
    try {
        const r=await fetch('/api/events/secteurs');
        if(!r.ok) throw 0;
        availableSecteurs = await r.json();
    } catch {
        availableSecteurs = [{nom:'CMS'},{nom:'FINITION'},{nom:'AUTRES'}];
    }
}
async function loadWeekData(){
    const weeksArr = buildWeeksArray();
    if(!weeksArr.length) return;
    showToast(`Chargement ${weeksArr.length} semaine(s)...`,'info');
    try {
        const usersRawList = await Promise.all(weeksArr.map(w=>fetchWeekUsersSingle(w).catch(()=>null)));
        const normalizedList = usersRawList.map(n=>normalizeSingleUsers(n));
        weeklyUsers = mergeUsers(normalizedList);

        const prsLists = await Promise.all(weeksArr.map(w=>fetchWeekPrsSingle(w).catch(()=>[])));
        let allPrs=[];
        prsLists.forEach(a=>{ if(Array.isArray(a)) allPrs = allPrs.concat(a); });

        const seen = new Set();
        const merged=[];
        allPrs.forEach(p=>{
            const id = p.id ?? p.Id ?? p.PrsId ?? null;
            if(id!=null){
                if(seen.has(id)) return;
                seen.add(id);
            }
            merged.push(p);
        });
        merged.sort((a,b)=> new Date(a.dateDebut || a.DateDebut) - new Date(b.dateDebut || b.DateDebut));
        window.weeklyPrsData = merged;

        updateWeekInfo();
        populateEmailFields(true);
        renderUsersInfoZone();
        showToast(`${merged.length} PRS fusionnées`,'success');
    } catch(e){
        console.error('[loadWeekData]', e);
        showToast('Erreur chargement data','error');
        window.weeklyPrsData = @Html.Raw(Json.Serialize(Model.SamplePrsData));
    }
}

