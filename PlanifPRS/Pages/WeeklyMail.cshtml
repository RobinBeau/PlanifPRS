@page
@model PlanifPRS.Pages.WeeklyMailModel
@{
    ViewData["Title"] = "Mail hebdo";
}

<style>
    #userInfo { animation: fadeInUp .3s ease-out; }
    @@keyframes fadeInUp {
        from { opacity:0; transform: translateY(10px); }
        to { opacity:1; transform: translateY(0); }
    }
    .modal-body .row .col-md-6 {
        border-left:3px solid #007bff;
        padding-left:10px;
    }
</style>

<div class="row">
    <div class="col-12">
        <div class="card shadow-lg border-0">
            <div class="card-header" style="background:linear-gradient(135deg,#2c3e50,#34495e);color:#fff;border-radius:15px 15px 0 0;">
                <h2 class="mb-0"><i class="fas fa-envelope me-2"></i>Génération du mail hebdomadaire</h2>
                <p class="mb-0 opacity-75">Synthèse automatique des PRS planifiées</p>
            </div>
            <div class="card-body" style="background:#f8f9fa;padding:30px;">

                <!-- Sélection semaine -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#3498db,#2980b9);border-radius:15px;">
                            <div class="card-body text-white">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar-week me-1"></i>Sélectionner la semaine
                                </label>
                                <div class="input-group">
                                    <input type="week" id="selectedWeek" class="form-control border-0 shadow-sm" value="@Model.CurrentWeek" style="border-radius:10px;">
                                    <button class="btn btn-light border-0 shadow-sm ms-2" type="button" onclick="loadWeekData()" style="border-radius:10px;">
                                        <i class="fas fa-sync-alt me-1"></i>Charger
                                    </button>
                                </div>
                                <small class="opacity-75">
                                    Semaine actuelle : S@(Model.WeekNumber) | Semaine prochaine : S@(Model.NextWeekNumber)
                                </small>
                                <div class="mt-2">
                                    <button type="button" class="btn btn-outline-light btn-sm me-2" onclick="selectCurrentWeek()" style="border-radius:10px;">
                                        <i class="fas fa-calendar-day me-1"></i>Semaine actuelle (S@(Model.WeekNumber))
                                    </button>
                                    <button type="button" class="btn btn-outline-light btn-sm" onclick="selectNextWeek()" style="border-radius:10px;">
                                        <i class="fas fa-calendar-plus me-1"></i>Semaine prochaine (S@(Model.NextWeekNumber))
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#27ae60,#229954);border-radius:15px;">
                            <div class="card-body text-white">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-cog me-1"></i>Options
                                </label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="includeWarnings" checked>
                                    <label class="form-check-label" for="includeWarnings">Inclure les avertissements/notes</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="groupBySection" checked>
                                    <label class="form-check-label" for="groupBySection">Grouper par secteur</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info semaine -->
                <div id="weekInfo" class="alert border-0 shadow-sm mb-4"
                     style="background:linear-gradient(135deg,#ecf0f1,#bdc3c7);border-radius:15px;">
                    <i class="fas fa-info-circle me-2 text-primary"></i>
                    <span id="weekInfoText" class="text-dark fw-bold">
                        Prêt à générer le mail pour la semaine actuelle (S@(Model.WeekNumber))
                    </span>
                </div>

                <!-- Actions -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#34495e,#2c3e50);border-radius:15px;">
                            <div class="card-body text-center">
                                <button type="button" class="btn btn-light btn-lg me-2 shadow-sm"
                                        onclick="generateMail()" style="border-radius:15px;border:none;">
                                    <i class="fas fa-magic me-2"></i>Générer le mail
                                </button>

                                <button type="button" class="btn btn-success btn-lg me-2 shadow-sm"
                                        onclick="downloadEMLFile()" id="emlBtn" disabled
                                        style="border-radius:15px;border:none;">
                                    <i class="fas fa-envelope-open me-2"></i>Télécharger .eml
                                </button>

                                <div class="btn-group me-2">
                                    <button type="button" class="btn btn-info btn-lg shadow-sm" id="outlookBtn"
                                            onclick="tryOpenInOutlook()" disabled
                                            style="border-radius:15px 0 0 15px;border:none;">
                                        <i class="fas fa-paper-plane me-2"></i>Envoyer
                                    </button>
                                    <button type="button" class="btn btn-success btn-lg dropdown-toggle dropdown-toggle-split shadow-sm"
                                            id="outlookDropdown" data-bs-toggle="dropdown" disabled
                                            style="border-radius:0 15px 15px 0;border:none;">
                                        <span class="visually-hidden">Options</span>
                                    </button>
                                    <ul class="dropdown-menu shadow-lg border-0" style="border-radius:15px;">
                                        <li><a class="dropdown-item" href="#" onclick="tryOpenInOutlook()">
                                            <i class="fas fa-external-link-alt me-2 text-primary"></i>Essayer mailto</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="copyTextAndShowInstructions()">
                                            <i class="fas fa-copy me-2 text-success"></i>Copier texte + instructions</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="copyHTMLAndShowInstructions()">
                                            <i class="fas fa-palette me-2 text-info"></i>Copier HTML + instructions</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="downloadHTMLFile()">
                                            <i class="fas fa-download me-2 text-warning"></i>Télécharger HTML</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="downloadEMLFile()">
                                            <i class="fas fa-envelope-open me-2 text-success"></i>Télécharger .eml</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="#" onclick="showManualInstructions()">
                                            <i class="fas fa-question-circle me-2 text-secondary"></i>Aide</a></li>
                                    </ul>
                                </div>

                                <button type="button" class="btn btn-outline-light shadow-sm" id="copyBtn"
                                        onclick="copyToClipboard()" disabled style="border-radius:15px;">
                                    <i class="fas fa-copy me-2"></i>Copier HTML
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Alerte mailto -->
                <div id="mailtoLimitAlert" class="d-none">
                    <div class="alert alert-warning border-0 shadow-sm" style="border-radius:15px;">
                        <h6><i class="fas fa-exclamation-triangle me-2"></i>Mail volumineux</h6>
                        <p class="mb-2">Trop gros pour ouverture directe Outlook.</p>
                        <div class="d-grid gap-2 d-md-flex">
                            <button class="btn btn-success btn-sm" onclick="copyTextAndShowInstructions()">
                                <i class="fas fa-copy me-1"></i>Copier texte</button>
                            <button class="btn btn-info btn-sm" onclick="generateShortVersion()">
                                <i class="fas fa-compress me-1"></i>Version courte</button>
                            <button class="btn btn-secondary btn-sm" onclick="downloadHTMLFile()">
                                <i class="fas fa-download me-1"></i>Télécharger</button>
                        </div>
                    </div>
                </div>

                <!-- Aperçu -->
                <div id="mailPreview" class="d-none">
                    <div class="card border-0 shadow-lg" style="background:#fff;border-radius:20px;border:1px solid #dee2e6;">
                        <div class="card-header border-0 text-white"
                             style="background:linear-gradient(135deg,#495057,#6c757d);border-radius:20px 20px 0 0;">
                            <h5 class="mb-0">
                                <i class="fas fa-eye me-2"></i>Aperçu du mail
                                <span id="mailSizeIndicator" class="badge ms-2" style="font-size:11px;"></span>
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>À :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailTo" class="form-control border-0 shadow-sm"
                                           placeholder="destinataires@exemple.com" style="border-radius:10px;">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>Cc :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailCc" class="form-control border-0 shadow-sm"
                                           placeholder="responsables@exemple.com" style="border-radius:10px;">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-2"><strong>Objet :</strong></div>
                                <div class="col-md-10">
                                    <input id="mailSubject" class="form-control border-0 shadow-sm"
                                           readonly style="border-radius:10px;background:#f8f9fa;">
                                </div>
                            </div>
                            <div class="border rounded shadow-sm p-4"
                                 style="background:#f8f9fa;border-radius:15px;border:1px solid #dee2e6;">
                                <div id="mailContent"
                                     style="font-family:'Segoe UI',sans-serif;background:#fff;padding:20px;border-radius:10px;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div id="mailStats" class="d-none mt-4">
                    <div class="row text-center">
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#2c3e50,#34495e);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalPrs">0</h4><small>PRS planifiées</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#3498db,#2980b9);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalLines">0</h4><small>Lignes utilisées</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#27ae60,#229954);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalDays">0</h4><small>Jours avec PRS</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-white"
                                 style="background:linear-gradient(135deg,#7f8c8d,#95a5a6);border-radius:15px;">
                                <div class="card-body">
                                    <h4 id="totalSections">0</h4><small>Secteurs actifs</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="weekUsersZone"></div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ====================== CONSTANTES & ETAT ====================== */
const currentWeek = '@Model.CurrentWeek';
const nextWeek = '@Model.NextWeek';
const currentWeekNumber = @Model.WeekNumber;
const nextWeekNumber = @Model.NextWeekNumber;
const MAILTO_LIMIT = 4500;

let availableSecteurs = [];
let weeklyUsers = { AllEmails: [], EmailsFormatted: '', TotalUsers: 0, UsersByService: [] };

/* Regex adaptées à Razor (pas de suivi de [) via \u0040 */
const EMAIL_REGEX_STRICT   = /^[A-Z0-9._%+-]+\u0040[A-Z0-9.-]+\.[A-Z]{2,}$/i; // domaine avec point
const EMAIL_REGEX_INTERNAL = /^[A-Z0-9._%+-]+\u0040[A-Z0-9.-]+$/i;            // accepte domaine sans point
const EMAIL_TOKEN_FINDER   = /[A-Z0-9._%+-]+\u0040[A-Z0-9.-]+\.[A-Z]{1,}/ig;

/* ====================== HELPERS UTILISATEURS ====================== */
function ensureWeeklyUsersShape() {
    if (!weeklyUsers || typeof weeklyUsers !== 'object')
        weeklyUsers = { AllEmails: [], EmailsFormatted: '', TotalUsers: 0, UsersByService: [] };
    if (!Array.isArray(weeklyUsers.AllEmails)) weeklyUsers.AllEmails = [];
    if (!Array.isArray(weeklyUsers.UsersByService)) weeklyUsers.UsersByService = [];
    weeklyUsers.EmailsFormatted ||= '';
    weeklyUsers.TotalUsers ||= 0;
}
function extractEmailsFromFormatted(formatted) {
    if (!formatted) return [];
    const angled = formatted.match(/<([^>]+)>/g);
    if (angled) {
        return angled.map(m=>m.replace(/[<>]/g,'').trim())
                     .filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    }
    return formatted.split(/[;, \n]+/)
        .map(e=>e.trim())
        .filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
}
function reconstructEmailsFromUsersByService(list) {
    if (!Array.isArray(list)) return [];
    const acc=[];
    list.forEach(s => (s.Utilisateurs||[]).forEach(u=>{
        const e = u?.Email || u?.email;
        if (e && (EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e)) && !acc.includes(e))
            acc.push(e);
    }));
    return acc;
}

// Destinataires fixes (front uniquement)
const ALWAYS_INCLUDE_EMAILS = [
  "direction@entreprise.com",
  "qualite@entreprise.com"
];

function collectAllEmails() {
    ensureWeeklyUsersShape();
    let raw = [];

    if (Array.isArray(weeklyUsers.AllEmails) && weeklyUsers.AllEmails.length) {
        weeklyUsers.AllEmails.forEach(e=>{
            if(typeof e==='string') raw.push(e);
            else if (e && typeof e==='object') {
                if (e.Email) raw.push(e.Email);
                if (e.email) raw.push(e.email);
            }
        });
    }
    if (!raw.length && weeklyUsers.EmailsFormatted) {
        raw.push(...extractEmailsFromFormatted(weeklyUsers.EmailsFormatted));
    }
    if (!raw.length && weeklyUsers.UsersByService.length) {
        raw.push(...reconstructEmailsFromUsersByService(weeklyUsers.UsersByService));
    }
    if (!raw.length) { // fallback extraction brute
        try {
            const matches = JSON.stringify(weeklyUsers).match(EMAIL_TOKEN_FINDER);
            if (matches) raw.push(...matches);
        } catch {}
    }

    raw = raw
        .map(x=>x && x.toString().trim())
        .filter(Boolean)
        .flatMap(x=>x.split(/[;,]+/))
        .map(x=>x.trim())
        .filter(Boolean);

    const dedup=[];
    raw.forEach(r=>{ if(!dedup.includes(r)) dedup.push(r); });

    let strictValid = dedup.filter(e=>EMAIL_REGEX_STRICT.test(e));
    const internal   = dedup.filter(e=>!EMAIL_REGEX_STRICT.test(e) && EMAIL_REGEX_INTERNAL.test(e));

    if (!strictValid.length && internal.length) strictValid = internal;
    if (!strictValid.length && dedup.length) {
        console.warn('[collectAllEmails] fallback permissif');
        strictValid = dedup;
    }
    console.log('[collectAllEmails] =>', strictValid);
            ALWAYS_INCLUDE_EMAILS.forEach(f => {
            if (f && !strictValid.some(e => e.toLowerCase() === f.toLowerCase())) {
                strictValid.push(f);
            }
        });
    return strictValid;
}

/* ====================== INIT ====================== */
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('selectedWeek').value = currentWeek;
    updateWeekInfo();
    loadSecteurs().then(loadWeekData);
    document.getElementById('selectedWeek').addEventListener('change', () => {
        updateWeekInfo();
        loadWeekData();
    });
});

/* ====================== CHARGEMENTS ====================== */
async function loadSecteurs() {
    try {
        const r = await fetch('/api/events/secteurs');
        if (!r.ok) throw 0;
        availableSecteurs = await r.json();
    } catch {
        availableSecteurs = [{nom:'CMS'},{nom:'FINITION'},{nom:'AUTRES'}];
    }
}

async function loadWeekUsers() {
    const w = document.getElementById('selectedWeek').value;
    if (!w) return;
    const r = await fetch(`/api/events/week-users?week=${w}`);
    if (!r.ok) throw new Error('HTTP '+r.status);
    weeklyUsers = await r.json();
    ensureWeeklyUsersShape();
    console.log('[loadWeekUsers] weeklyUsers=', weeklyUsers);
    populateEmailFields();
}

async function loadWeekData() {
    const w = document.getElementById('selectedWeek').value;
    if (!w) return;
    showToast('Chargement...', 'info');
    try {
        await loadWeekUsers(); // attendre les utilisateurs AVANT
        const prs = await fetch(`/api/events/week?week=${w}`).then(r=>r.json());
        window.weeklyPrsData = prs;
        showToast(`${prs.length} PRS trouvées`, 'success');
        populateEmailFields(); // re-sécurise après PRS
    } catch (e) {
        console.error(e);
        showToast('Erreur chargement PRS','error');
        window.weeklyPrsData = @Html.Raw(Json.Serialize(Model.SamplePrsData));
    }
}

/* ====================== SEMAINE UI ====================== */
function selectCurrentWeek(){ document.getElementById('selectedWeek').value=currentWeek; updateWeekInfo(); loadWeekData(); showToast(`Semaine actuelle (S${currentWeekNumber})`,'info'); }
function selectNextWeek(){ document.getElementById('selectedWeek').value=nextWeek; updateWeekInfo(); loadWeekData(); showToast(`Semaine prochaine (S${nextWeekNumber})`,'info'); }
function updateWeekInfo(){
    const w=document.getElementById('selectedWeek').value; if(!w) return;
    const [y,wn]=w.split('-W'); const n=parseInt(wn);
    let txt=`Semaine S${n} de ${y}`;
    if(n===currentWeekNumber) txt+=' (semaine actuelle)';
    else if(n===nextWeekNumber) txt+=' (semaine prochaine)';
    else if(n<currentWeekNumber) txt+=' (semaine passée)'; else txt+=' (semaine future)';
    document.getElementById('weekInfoText').textContent=`Mail à générer pour la ${txt}`;
}

/* ====================== DESTINATAIRES ====================== */
function populateEmailFields() {
    const emails = collectAllEmails();
    if (!emails.length) {
        console.warn('[populateEmailFields] aucune adresse pour le moment.');
        return;
    }
    const field=document.getElementById('mailTo');
    if(field && (!field.value || !field.value.trim())) {
        field.value = emails.join(', ');
    }
    showUsersInfo();
}
function showUsersInfo(){
    ensureWeeklyUsersShape();
    if(!weeklyUsers.TotalUsers) return;
    let zone=document.getElementById('userInfo');
    const row=document.getElementById('mailTo')?.closest('.row');
    if(!zone && row){
        zone=document.createElement('div');
        zone.id='userInfo';
        zone.className='alert alert-info border-0 shadow-sm mt-2';
        zone.style.borderRadius='10px';
        row.parentNode.insertBefore(zone,row.nextSibling);
    }
    if(zone){
        zone.innerHTML=`
          <div class="d-flex align-items-center">
            <i class="fas fa-users me-2 text-primary"></i>
            <span><strong>${weeklyUsers.TotalUsers} utilisateurs</strong> associés à cette semaine</span>
            <button type="button" class="btn btn-outline-primary btn-sm ms-auto" onclick="showUsersDetails()">
              <i class="fas fa-eye me-1"></i>Détails
            </button>
          </div>`;
    }
}
function showUsersDetails(){
    ensureWeeklyUsersShape();
    if(!weeklyUsers.UsersByService.length) return;
    const old=document.getElementById('usersModal'); if(old) old.remove();
    let html=`<div class="modal fade" id="usersModal" tabindex="-1">
      <div class="modal-dialog modal-lg"><div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-users me-2"></i>Utilisateurs (${weeklyUsers.TotalUsers})</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">`;
    weeklyUsers.UsersByService.forEach(s=>{
        html+=`<div class="mb-4"><h6 class="text-primary border-bottom pb-2">🏢 ${s.Service} (${s.Utilisateurs.length})</h6><div class="row">`;
        (s.Utilisateurs||[]).forEach(u=>{
            html+=`<div class="col-md-6 mb-2">
              <div class="d-flex align-items-center">
                <i class="fas fa-user me-2 text-muted"></i>
                <div><strong>${u.Prenom} ${u.Nom}</strong><br><small class="text-muted">${u.Email}</small></div>
              </div>
            </div>`;
        });
        html+='</div></div>';
    });
    html+=`<div class="border-top pt-3">
        <label class="form-label">Emails formatés :</label>
        <textarea class="form-control" rows="3" readonly onclick="this.select()">${weeklyUsers.EmailsFormatted}</textarea>
      </div></div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
        <button class="btn btn-primary" onclick="copyAllEmails()"><i class="fas fa-copy me-1"></i>Copier tous</button>
      </div>
    </div></div></div>`;
    document.body.insertAdjacentHTML('beforeend',html);
    new bootstrap.Modal(document.getElementById('usersModal')).show();
}
function copyAllEmails(){
    let emails = collectAllEmails();
    if(!emails.length) return;
    navigator.clipboard.writeText(emails.join('; '))
        .then(()=>showToast('📧 Emails copiés','success'))
        .catch(()=>showToast('Erreur copie','error'));
}

/* ====================== GÉNÉRATION MAIL ====================== */
function generateMail(){
    const w=document.getElementById('selectedWeek').value;
    if(!w) return showToast('Sélectionne une semaine','warning');
    const prs=window.weeklyPrsData||[];
    if(!prs.length) return showToast('Aucune PRS','warning');
    const [y,wn]=w.split('-W'); const wk=parseInt(wn);
    const incl=document.getElementById('includeWarnings').checked;
    const group=document.getElementById('groupBySection').checked;
    const subject=`Planning PRS S${wk} - Semaine du ${getWeekDateRange(y,wk)}`;
    const html=generateCleanEmailHTML(prs,wk,y,incl,group);
    const text=generateFormattedTextEmail(prs,wk,y,incl,group);
    document.getElementById('mailSubject').value=subject;
    document.getElementById('mailContent').innerHTML=html;
    document.getElementById('mailPreview').classList.remove('d-none');
    ['outlookBtn','outlookDropdown','copyBtn','emlBtn'].forEach(id=>document.getElementById(id).disabled=false);
    updateStats(prs,group);
    document.getElementById('mailStats').classList.remove('d-none');
    populateEmailFields();
    checkMailtoSize(text,subject);
    showToast('Mail généré','success');
}
function checkMailtoSize(textBody,subject){
    const payload=`subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(textBody)}`;
    const size=payload.length;
    const badge=document.getElementById('mailSizeIndicator');
    if(size>MAILTO_LIMIT){
        badge.textContent=`${size} car. - Trop volumineux`;
        badge.className='badge bg-danger ms-2';
        document.getElementById('mailtoLimitAlert').classList.remove('d-none');
        const b=document.getElementById('outlookBtn');
        b.innerHTML='<i class="fas fa-exclamation-triangle me-2"></i>Trop volumineux';
        b.className='btn btn-warning btn-lg shadow-sm';
    } else {
        badge.textContent=`${size} car. - OK`;
        badge.className='badge bg-success ms-2';
        document.getElementById('mailtoLimitAlert').classList.add('d-none');
        const b=document.getElementById('outlookBtn');
        b.innerHTML='<i class="fas fa-paper-plane me-2"></i>Envoyer';
        b.className='btn btn-info btn-lg shadow-sm';
    }
}
function generateShortVersion(){
    const w=document.getElementById('selectedWeek').value;
    const [y,wn]=w.split('-W'); const wk=parseInt(wn);
    const prs=window.weeklyPrsData||[];
    const sections={};
    prs.forEach(p=>{ const s=determineSecteurFromPRS(p); (sections[s] ||= []).push(p); });
    let txt=`📅 PLANNING PRS S${wk} - ${getWeekDateRange(y,wk)}\n\nBonjour,\n\nRésumé :\n\n`;
    Object.keys(sections).sort().forEach(sec=>{
        txt+=`🏭 ${sec}: ${sections[sec].length} PRS\n`;
        sections[sec].slice(0,3).forEach(p=>{
            const d=formatPrsDate(p.dateDebut);
            const t=new Date(p.dateDebut).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
            txt+=`• ${d} ${t} - ${p.description}\n`;
        });
        if(sections[sec].length>3) txt+=`... et ${sections[sec].length-3} autres\n`;
        txt+='\n';
    });
    document.getElementById('mailContent').innerHTML = `<div style="font-family:Arial">${txt.replace(/\n/g,'<br>')}</div>`;
    checkMailtoSize(txt,`Planning PRS S${wk}`);
    showToast('Version courte prête','info');
}

