function copyHTMLAndShowInstructions(){
    const html=document.getElementById('mailContent').innerHTML;
    navigator.clipboard.writeText(html).then(()=>{ showToast('HTML copié','success'); showSimpleInstructions(); })
        .catch(()=>showToast('Erreur copie','error'));
}
function showSimpleInstructions(){
    const id='htmlInstructionsAlert'; const old=document.getElementById(id); if(old) old.remove();
    const div=document.createElement('div');
    div.id=id;
    div.innerHTML=`<div class="alert alert-success alert-dismissible fade show position-fixed"
        style="top:80px;right:20px;z-index:9999;max-width:500px;">
        <h6><i class="fas fa-check-circle me-2"></i>HTML copié</h6>
        <p>Collez dans le corps du mail (Outlook Web / Gmail).</p>
        <button class="btn-close" onclick="this.closest('.alert').remove()"></button>
    </div>`;
    document.body.appendChild(div);
    setTimeout(()=>div.remove(),15000);
}
function copyToClipboard(){
    const html=document.getElementById('mailContent').innerHTML;
    navigator.clipboard.writeText(html).then(()=>showToast('HTML copié','success'))
        .catch(()=>showToast('Erreur copie','error'));
}
function downloadHTMLFile(){
    const content=document.getElementById('mailContent').innerHTML;
    const blob=new Blob([content],{type:'text/html;charset=utf-8'});
    const url=URL.createObjectURL(blob);
    const weeksArr = buildWeeksArray();
    const label = buildWeeksLabelForHeader(weeksArr).replace(/[^\w\-]+/g,'_');
    const a=document.createElement('a');
    a.href=url; a.download=`Planning_PRS_${label}.html`;
    document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
    showToast('HTML téléchargé','success');
}
function downloadEMLFile(){
    ensureWeeklyUsersShape();
    const weeksArr = buildWeeksArray();
    if(!weeksArr.length){ showToast('Pas de semaine sélectionnée','warning'); return; }
    let toRaw=document.getElementById('mailTo').value?.trim();
    if(!toRaw){
        const collected=collectAllEmails();
        if(collected.length){
            toRaw=collected.join(', ');
            document.getElementById('mailTo').value=toRaw;
        }
    }
    let toList=(toRaw||'').split(/[;,]+/).map(x=>x.trim()).filter(Boolean);
    let filtered=toList.filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    if(!filtered.length && toList.length) filtered=toList;
    if(!filtered.length){
        showToast('Aucun destinataire valide','warning');
        return;
    }
    const toHeader=filtered.join(', ');
    const ccRaw=document.getElementById('mailCc').value?.trim();
    const ccList=(ccRaw||'').split(/[;,]+/).map(x=>x.trim()).filter(e=>EMAIL_REGEX_STRICT.test(e)||EMAIL_REGEX_INTERNAL.test(e));
    const ccHeader=ccList.join(', ');
    const subject=document.getElementById('mailSubject').value;
    if(!subject){ showToast('Génère d\'abord le mail','warning'); return; }
    const incl=document.getElementById('includeWarnings').checked;
    const group=document.getElementById('groupBySection').checked;
    const prs=window.weeklyPrsData||[];
    const firstP = parseWeekString(weeksArr[0]) || {week:0,year:new Date().getFullYear()};
    let body=generateFormattedTextEmail(prs, firstP.week, firstP.year, incl, group, weeksArr);
    if(weeklyUsers.TotalUsers) body+=`\n\n📧 Destinataires auto: ${weeklyUsers.TotalUsers} utilisateurs.`;
    const eml=generateEMLContent(toHeader,ccHeader,subject,body);
    const blob=new Blob([eml],{type:'message/rfc822'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    const label=buildWeeksLabelForHeader(weeksArr).replace(/[^\w\-]+/g,'_');
    a.href=url; a.download=`Planning_PRS_${label}.eml`;
    document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
    showToast(`.eml généré (${filtered.length} destinataires)`,'success');
}
function generateEMLContent(to,cc,subject,textBody){
    const date=new Date().toUTCString();
    const encodeHeader=s=>/^[\x00-\x7F]*$/.test(s)?s:'=?UTF-8?B?'+btoa(unescape(encodeURIComponent(s)))+'?=';
    const CRLF=s=>s.replace(/\r?\n/g,'\r\n');
    let eml='';
    eml+='Date: '+date+'\r\n';
    eml+='X-Unsent: 1\r\n';
    eml+='To: '+to+'\r\n';
    if(cc) eml+='Cc: '+cc+'\r\n';
    eml+='Subject: '+encodeHeader(subject)+'\r\n';
    eml+='MIME-Version: 1.0\r\n';
    eml+='Content-Type: text/plain; charset="UTF-8"\r\n';
    eml+='Content-Transfer-Encoding: 8bit\r\n';
    eml+='X-Mailer: PlanifPRS\r\n\r\n';
    eml+=textBody+'\r\n';
    return CRLF(eml);
}

/* ====================== TOAST ====================== */
function showToast(msg,type='info'){
    const id='__simple_toast'; const old=document.getElementById(id); if(old) old.remove();
    const div=document.createElement('div');
    const colors={success:'#28a745',info:'#0d6efd',warning:'#ffc107',error:'#dc3545'};
    div.id=id;
    div.style.cssText='position:fixed;bottom:20px;right:20px;z-index:9999;padding:10px 15px;border-radius:6px;color:#fff;font-size:14px;font-family:Arial;box-shadow:0 4px 12px #0003;';
    div.style.background=colors[type]||'#0d6efd';
    div.textContent=msg;
    document.body.appendChild(div);
    setTimeout(()=>div.remove(),3500);
}
